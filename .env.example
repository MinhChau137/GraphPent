# Database
POSTGRES_DB=pentest_graphrag
POSTGRES_USER=graphrag_user
POSTGRES_PASSWORD=SuperSecret123!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Weaviate
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=  # empty for anonymous lab

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=graphrag-bucket

# Backend
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_TARGETS=127.0.0.1,localhost,192.168.1.100,dvwa.local,juice-shop.local,webgoat.local
MAX_TOOL_TIMEOUT=300
RATE_LIMIT_PER_MIN=30

# Ollama (sẽ dùng từ Phase 5)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text-v1.5

# Nuclei
NUCLEI_ENDPOINT=http://nuclei:8080
NUCLEI_TIMEOUT=300

# Weaviate connection
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ── Tunable parameters (Phase 10-13) ──────────────────────────────────
# RRF Retrieval — tăng alpha → ưu tiên vector; giảm → ưu tiên graph
RRF_ALPHA=0.7
RRF_K=60.0

# LLM Extraction confidence gates — hạ xuống nếu graph quá thưa
ENTITY_CONFIDENCE_THRESHOLD=0.85
RELATION_CONFIDENCE_THRESHOLD=0.75

# KG Completion (Phase 11)
KG_MIN_CONFIDENCE=0.65
KG_MAX_DEGREE=2

# GNN Risk weights — phải cộng bằng 1.0 (Phase 12)
GNN_W_PAGERANK=0.50
GNN_W_SEVERITY=0.30
GNN_W_BETWEENNESS=0.20

# Workflow feedback loop (Phase 10)
MAX_LOOP_ITERATIONS=3

# Nmap collection — comma-separated flags (Phase 10)
NMAP_OPTIONS=-sV,-sC,--top-ports,1000

# Attack-path depth (Phase 12)
ATTACK_PATH_MAX_HOPS=4