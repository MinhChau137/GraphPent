# Database
POSTGRES_DB=pentest_graphrag
POSTGRES_USER=graphrag_user
POSTGRES_PASSWORD=SuperSecret123!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Weaviate
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=  # empty for anonymous lab

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=graphrag-bucket

# Backend
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_TARGETS=127.0.0.1,localhost,192.168.1.100,dvwa.local,juice-shop.local,webgoat.local
MAX_TOOL_TIMEOUT=300
RATE_LIMIT_PER_MIN=30

# Ollama (sẽ dùng từ Phase 5)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text-v1.5