UNWIND [{id:"cve-2026-0010", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"Out of bounds write in IDrmManagerService.cpp", created_at:datetime('2026-05-01T17:51:18.385Z')}}, {id:"cve-2026-0006", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Heap Buffer Overflow in Android", created_at:datetime('2026-05-01T17:51:50.255Z')}}, {id:"cve-2026-0012", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"Contact Name Leak in Android", created_at:datetime('2026-05-01T17:52:48.479Z')}}, {id:"cve-2026-0008", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Privilege Escalation due to Confused Deputy", created_at:datetime('2026-05-01T17:53:15.82Z')}}, {id:"cve-2026-0013", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"Local Escalation of Privilege in Android", created_at:datetime('2026-05-01T17:54:16.115Z')}}, {id:"cve-2026-0011", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Local Privilege Escalation in Android Settings", created_at:datetime('2026-05-01T17:54:47.242Z')}}, {id:"cve-2026-0015", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Persistent Denial of Service (DoS) in AppOpsService.java", created_at:datetime('2026-05-01T17:55:15.528Z')}}, {id:"cve-2026-0014", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Persistent Denial of Service in AppOpsService.java", created_at:datetime('2026-05-01T17:55:43.521Z')}}, {id:"cve-2026-0017", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Local Escalation of Privilege in BiometricService.java", created_at:datetime('2026-05-01T17:56:12.485Z')}}, {id:"cve-2026-0005", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"Partial bypass of app pinning in KeyguardServiceDelegate.java", created_at:datetime('2026-05-01T17:57:07.009Z')}}, {id:"cve-2026-0007", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"Tapjacking/Overlay Attack in Android", created_at:datetime('2026-05-01T17:57:59.373Z')}}, {id:"cve-2026-0020", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Permissions Bypass in Android", created_at:datetime('2026-05-01T17:58:29.252Z')}}, {id:"cve-2026-0023", properties:{pagerank_score:0.16666666666666666, risk_score:0.0967, name:"Local Privilege Escalation in Android's PackageInstallerService", created_at:datetime('2026-05-01T17:59:07.489Z')}}, {id:"cve-2026-0025", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Permissions Bypass in Android Notification.java", created_at:datetime('2026-05-01T17:59:42.447Z')}}, {id:"cve-2026-0021", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Cross-user permission bypass in AppInfoBase.java", created_at:datetime('2026-05-01T18:00:16.124Z')}}, {id:"cve-2026-0024", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Insecure permission check in MediaProvider.java", created_at:datetime('2026-05-01T18:00:48.73Z')}}, {id:"cve-2026-0026", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Local Privilege Escalation in Android Permission Manager", created_at:datetime('2026-05-01T18:01:21.239Z')}}, {id:"cve-2026-0028", properties:{pagerank_score:0.2857142857142857, risk_score:0.1086, name:"Integer Overflow in __pkvm_host_share_guest of mem_protect.c", created_at:datetime('2026-05-01T18:05:29.645Z')}}, {id:"cve-2026-0031", properties:{pagerank_score:0.16666666666666666, risk_score:0.0967, name:"Integer Overflow in Android Kernel", created_at:datetime('2026-05-01T18:06:04.543Z')}}, {id:"cve-2026-0034", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Notification policy desync in Android", created_at:datetime('2026-05-01T18:08:43.915Z')}}, {id:"cve-2026-0032", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Out-of-bounds write in mem_pro