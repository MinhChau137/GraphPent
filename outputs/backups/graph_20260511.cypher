CREATE FULLTEXT INDEX nodeSearch FOR (n:Weakness|CWE|CVE|Mitigation|Consequence|AffectedPlatform|Vulnerability) ON EACH [n.`name`,n.`id`,n.`description`];
CREATE RANGE INDEX FOR (n:Asset) ON (n.name);
CREATE RANGE INDEX FOR (n:CVE) ON (n.id);
CREATE RANGE INDEX FOR (n:CWE) ON (n.id);
CREATE RANGE INDEX FOR (n:Category) ON (n.name);
CREATE RANGE INDEX FOR (n:Host) ON (n.ip);
CREATE RANGE INDEX FOR (n:Vulnerability) ON (n.severity);
CREATE RANGE INDEX FOR (n:Weakness) ON (n.abstraction);
CREATE RANGE INDEX FOR (n:Weakness) ON (n.cweId);
CREATE RANGE INDEX FOR (n:Weakness) ON (n.name);
CREATE CONSTRAINT apiendpoint_id FOR (node:APIEndpoint) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT application_id FOR (node:Application) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT asset_id FOR (node:Asset) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT category_id FOR (node:Category) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT consequence_id FOR (node:Consequence) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT cve_id FOR (node:CVE) REQUIRE (node.cveId) IS UNIQUE;
CREATE CONSTRAINT cwe_id FOR (node:CWE) REQUIRE (node.cweId) IS UNIQUE;
CREATE CONSTRAINT domain_id FOR (node:Domain) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT host_id FOR (node:Host) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT ip_id FOR (node:IP) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT mitigation_id FOR (node:Mitigation) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT service_id FOR (node:Service) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT url_id FOR (node:URL) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT vulnerability_id FOR (node:Vulnerability) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT weakness_id FOR (node:Weakness) REQUIRE (node.id) IS UNIQUE;
CREATE CONSTRAINT UNIQUE_IMPORT_NAME FOR (node:`UNIQUE IMPORT LABEL`) REQUIRE (node.`UNIQUE IMPORT ID`) IS UNIQUE;
