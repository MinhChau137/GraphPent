, risk_score:0.3806, name:"Insecure Temporary File Vulnerability in NVIDIA Base Command Manager and Bright Cluster Manager", created_at:datetime('2026-05-02T21:29:31.843Z')}}, {id:"cve-2024-0166", properties:{severity:"HIGH", cvss_version:"3.1", pagerank_score:0.16666666666666666, cvss_score:7.8, cvss_vector:"CVSS:3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:H", risk_score:0.6407, name:"OS Command Injection Vulnerability in Dell Unity svc_tcpdump utility", created_at:datetime('2026-05-02T21:45:22.778Z')}}, {id:"cve-2024-0187", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Community by PeepSo WordPress plugin Reflected Cross-Site Scripting", created_at:datetime('2026-05-02T23:49:59.284Z')}}, {id:"CVE-2024-0203", properties:{severity:"HIGH", cvss_version:"3.1", pagerank_score:0.09090909090909091, cvss_score:8.8, cvss_vector:"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H", risk_score:0.7131, name:"Cross-Site Request Forgery in Digits plugin for WordPress", created_at:datetime('2026-05-03T00:11:33.127Z')}}, {id:"cve-2024-0222", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Use after free in ANGLE in Google Chrome prior to 120.0.6099.199", created_at:datetime('2026-05-03T00:22:04.61Z')}}, {id:"cve-2024-0223", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Heap buffer overflow in ANGLE in Google Chrome prior to 120.0.6099.199", created_at:datetime('2026-05-03T00:24:11.449Z')}}, {id:"cve-2024-0225", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Use after free in WebGPU in Google Chrome prior to 120.0.6099.199", created_at:datetime('2026-05-03T00:24:44.087Z')}}, {id:"cve-2024-0224", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Use after free in WebAudio in Google Chrome prior to 120.0.6099.199", created_at:datetime('2026-05-03T00:25:24.317Z')}}, {id:"CVE-2024-0233", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Reflected Cross-Site Scripting in EventON WordPress plugin", created_at:datetime('2026-05-03T00:27:56.363Z')}}, {id:"cve-2024-0230", properties:{severity:"LOW", cvss_version:"3.1", pagerank_score:0.09090909090909091, cvss_score:2.4, cvss_vector:"CVSS:3.1/AV:P/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N", risk_score:0.2011, name:"Session Management Issue in Magic Keyboard Firmware", created_at:datetime('2026-05-03T00:29:22.46Z')}}, {id:"cve-2024-0235", properties:{pagerank_score:0.23076923076923078, risk_score:0.1031, name:"EventON WordPress plugin authorization bypass", created_at:datetime('2026-05-03T00:32:10.196Z')}}, {id:"cve-2024-0236", properties:{pagerank_score:0.16666666666666666, risk_score:0.0967, name:"EventON WordPress plugin authorization bypass", created_at:datetime('2026-05-03T00:33:11.628Z')}}, {id:"CVE-2024-0239", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Reflected Cross-Site Scripting in Contact Form 7 Connector WordPress plugin", created_at:datetime('2026-05-03T00:33:42.973Z')}}, {id:"cve-2024-0238", properties:{pagerank_score:0.16666666666666666, risk_score:0.0967, name:"Unauthorised Post Update in EventON Premium WordPress Plugin", created_at:datetime('2026-05-03T00:34:24.338Z')}}, {id:"cve-2024-0250", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Open Redirect in Analytics Insights for Google Analytics 4 (AIWP) WordPress plugin", created_at:datetime('2026-05-03T00:43:32.209Z')}}, {id:"CVE-2024-0249", properties:{pagerank_score:0.09090909090909091, risk_score:0.0891, name:"Reflected Cross-Site Scripting in Advanced Schedule Posts WordPress plugin", created_at:datetime('2026-05-03T00:44:42.817Z')}}, {id:"cve-2023-0033", properties:{cve_id:"CVE-2023-0033", name:"Stored Cross-Site Scripting (XSS) in PDF Viewer WordPress plugin", description:"The PDF Viewer WordPress plugin before 1.0.0 does not validate and escape one of its shortcode attributes, which could allow users with a role as low as contributor to perform Stored Cross-Site Scripting attack.", created_at:datetime('2026-05-10T10:59:04.223Z'), published_date:"2023-01-30T20:31:53.710Z"}}, {id:"CVE-2023-0034", properties:{cve_id:"CVE-2023-0034", name:"Stored Cross-Site Scripting (XSS) in JetWidgets For Elementor plugin", description:"The JetWidgets For Elementor WordPress plugin before 1.0.14 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T11:00:10.989Z'), published_date:"2023-02-13T14:32:25.406Z"}}, {id:"CVE-2023-0037", properties:{cve_id:"CVE-2023-0037", name:"SQL Injection in 10Web Map Builder for Google Maps WordPress plugin", description:"The 10Web Map Builder for Google Maps WordPress plugin before 1.0.73 does not properly sanitise and escape some parameters before using them in an SQL statement via an AJAX action available to unauthenticated users, leading to a SQL injection", created_at:datetime('2026-05-10T11:01:10.105Z'), published_date:"2023-03-13T16:03:32.276Z"}}, {id:"cve-2023-0043", properties:{cve_id:"2023-0043", name:"Reflected Cross-Site Scripting in Custom Add User WordPress plugin", description:"The Custom Add User WordPress plugin through 2.0.2 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high privilege users such as admin", created_at:datetime('2026-05-10T11:04:11.095Z'), published_date:"2023-02-27T15:24:41.583Z"}}, {id:"cve-2023-0042", properties:{cve_id:"CVE-2023-0042", name:"GitLab Pages arbitrary protocol redirection", description:"An issue has been discovered in GitLab CE/EE affecting all versions starting from 11.4 prior to 15.5.7, 15.6 prior to 15.6.4, and 15.7 prior to 15.7.2. GitLab Pages allows redirection to arbitrary protocols.", created_at:datetime('2026-05-10T11:04:52.635Z'), published_date:"2023-01-12T00:00:00.000Z"}}, {id:"CVE-2023-0044", properties:{cve_id:"CVE-2023-0044", name:"Information Disclosure in Quarkus Form Authentication", description:"If the Quarkus Form Authentication session cookie Path attribute is set to `/` then a cross-site attack may be initiated which might lead to the Information Disclosure. This attack can be prevented with the Quarkus CSRF Prevention feature.", created_at:datetime('2026-05-10T11:10:46.861Z'), published_date:"2023-02-23T00:00:00.000Z"}}, {id:"CVE-2023-0050", properties:{cve_id:"CVE-2023-0050", name:"Stored XSS in GitLab Kroki diagram", created_at:datetime('2026-05-10T11:11:19.766Z'), description:"An issue has been discovered in GitLab affecting all versions starting from 13.7 before 15.7.8, all versions starting from 15.8 before 15.8.4, all versions starting from 15.9 before 15.9.2. A specially crafted Kroki diagram could lead to a stored XSS on the client side which allows attackers to perform arbitrary actions on behalf of victims.", published_date:"2023-03-09T00:00:00.000Z"}}, {id:"cve-2023-0060", properties:{cve_id:"CVE-2023-0060", name:"Stored Cross-Site Scripting (XSS) in Responsive Gallery Grid", description:"The Responsive Gallery Grid WordPress plugin before 2.3.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:20:27.488Z'), published_date:"2023-02-13T14:32:06.427Z"}}, {id:"cve-2023-0061", properties:{cve_id:"CVE-2023-0061", name:"Judge.me Product Reviews for WooCommerce WordPress plugin vulnerability", description:"The Judge.me Product Reviews for WooCommerce WordPress plugin before 1.3.21 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:20:58.869Z'), published_date:"2023-02-13T14:32:15.138Z"}}, {id:"CVE-2023-0059", properties:{cve_id:"CVE-2023-0059", name:"Youzify WordPress Plugin Vulnerability", description:"The Youzify WordPress plugin before 1.2.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:21:28.784Z'), updated_date:"2025-03-12T20:51:33.309Z", published_date:"2023-02-21T08:51:00.517Z"}}, {id:"CVE-2023-0062", properties:{cve_id:"CVE-2023-0062", name:"EAN for WooCommerce WordPress plugin vulnerability", description:"The EAN for WooCommerce WordPress plugin before 4.4.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:21:58.655Z'), updated_date:"2025-03-25T18:09:07.360Z", published_date:"2023-02-06T19:59:33.722Z"}}, {id:"CVE-2023-0058", properties:{cve_id:"CVE-2023-0058", name:"Tiempo.com WordPress plugin vulnerability", description:"The Tiempo.com WordPress plugin through 0.1.2 does not have CSRF check when creating and editing its shortcode, and is missing sanitisation as well as escaping, which could allow attackers to make logged in admin add Stored XSS payloads via a CSRF attack", created_at:datetime('2026-05-10T11:22:27.615Z'), updated_date:"2024-08-02T04:54:32.601Z", published_date:"2023-08-16T11:03:23.680Z"}}, {id:"CVE-2023-0065", properties:{cve_id:"CVE-2023-0065", name:"i2 Pros & Cons WordPress plugin vulnerability", description:"The i2 Pros & Cons WordPress plugin through 1.3.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:22:58.949Z'), updated_date:"2025-03-06T14:57:42.361Z", published_date:"2023-03-06T13:34:06.872Z"}}, {id:"cve-2023-0067", properties:{cve_id:"CVE-2023-0067", name:"Timed Content WordPress plugin vulnerability", description:"The Timed Content WordPress plugin before 2.73 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:23:27.32Z'), published_date:"2023-02-21T08:50:41.315Z"}}, {id:"CVE-2023-0066", properties:{cve_id:"CVE-2023-0066", name:"Stored Cross-Site Scripting (XSS) in Companion Sitemap Generator WordPress plugin", description:"The Companion Sitemap Generator WordPress plugin through 4.5.1.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:23:58.204Z'), published_date:"2023-03-13T16:03:28.952Z"}}, {id:"CVE-2023-0063", properties:{cve_id:"CVE-2023-0063", name:"WordPress Shortcodes plugin vulnerability", description:"The WordPress Shortcodes WordPress plugin through 1.6.36 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:24:34.254Z'), updated_date:"2025-03-06T15:08:55.653Z", published_date:"2023-03-06T13:34:02.007Z"}}, {id:"CVE-2023-0064", properties:{cve_id:"CVE-2023-0064", name:"WordPress Plugin Vulnerability", created_at:datetime('2026-05-10T11:25:04.192Z'), description:"The eVision Responsive Column Layout Shortcodes WordPress plugin through 2.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", updated_date:"2025-03-06T15:00:19.595Z", published_date:"2023-03-06T13:34:06.078Z"}}, {id:"CVE-2023-0068", properties:{cvss_severity:"CRITICAL", cvss_score:9.8, cve_id:"CVE-2023-0068", name:"Stored Cross-Site Scripting (XSS) in WooCommerce GTIN validation", created_at:datetime('2026-05-10T11:25:40.594Z'), description:"The Product GTIN (EAN, UPC, ISBN) for WooCommerce WordPress plugin through 1.1.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", published_date:"2023-03-06T13:34:02.785Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0069", properties:{cve_id:"CVE-2023-0069", name:"WPaudio MP3 Player WordPress plugin vulnerability", description:"The WPaudio MP3 Player WordPress plugin through 4.0.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:26:10.186Z'), published_date:"2023-03-06T13:34:07.685Z"}}, {id:"cve-2023-0070", properties:{cve_id:"CVE-2023-0070", name:"Stored Cross-Site Scripting (XSS) in ResponsiveVoice Text To Speech plugin", description:"The ResponsiveVoice Text To Speech WordPress plugin before 1.7.7 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:26:40.108Z'), published_date:"2023-02-06T19:59:13.338Z"}}, {id:"CVE-2023-0071", properties:{cve_id:"CVE-2023-0071", name:"WP Tabs WordPress plugin vulnerability", description:"The WP Tabs WordPress plugin before 2.1.17 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:27:10.923Z'), updated_date:"2025-03-27T20:06:57.897Z", published_date:"2023-01-30T20:31:33.172Z"}}, {id:"CVE-2023-0072", properties:{cve_id:"CVE-2023-0072", name:"WC Vendors Marketplace WordPress plugin vulnerability", description:"The WC Vendors Marketplace WordPress plugin before 2.4.5 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:27:40.802Z'), updated_date:"2025-03-25T17:41:37.201Z", published_date:"2023-02-06T19:59:47.480Z"}}, {id:"cve-2023-0074", properties:{cve_id:"2023-0074", name:"WP Social Widget WordPress plugin vulnerability", description:"The WP Social Widget WordPress plugin before 2.2.4 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:28:10.435Z'), published_date:"2023-01-30T20:31:45.765Z"}}, {id:"cve-2023-0073", properties:{cve_id:"CVE-2023-0073", name:"Client Logo Carousel WordPress plugin vulnerability", description:"The Client Logo Carousel WordPress plugin through 3.0.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:28:40.109Z'), updated_date:"2025-02-27T15:44:43.170Z", published_date:"2023-03-13T16:03:37.192Z"}}, {id:"CVE-2023-0076", properties:{cve_id:"CVE-2023-0076", name:"Stored Cross-Site Scripting (XSS) in Download Attachments plugin", description:"The Download Attachments WordPress plugin before 1.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:29:09.445Z'), published_date:"2023-03-06T13:33:57.963Z"}}, {id:"cve-2023-0079", properties:{cvss_score:8.5, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0079", name:"Stored Cross-Site Scripting (XSS) in Customer Reviews for WooCommerce", created_at:datetime('2026-05-10T11:29:39.466Z'), description:"The Customer Reviews for WooCommerce WordPress plugin before 5.17.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", published_date:"2024-01-16T15:54:58.622Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0075", properties:{cve_id:"CVE-2023-0075", name:"Amazon JS WordPress Plugin Vulnerability", description:"The Amazon JS WordPress plugin through 0.10 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:30:13.786Z'), updated_date:"2025-03-21T19:39:00.907Z", published_date:"2023-02-13T14:32:24.576Z"}}, {id:"cve-2023-0077", properties:{cve_id:"CVE-2023-0077", name:"Integer overflow or wraparound vulnerability in CGI component in Synology Router Manager (SRM)", description:"Integer overflow or wraparound vulnerability in CGI component in Synology Router Manager (SRM) before 1.2.5-8227-6 and 1.3.1-9346-3 allows remote attackers to overflow buffers via unspecified vectors.", created_at:datetime('2026-05-10T11:30:55.181Z'), published_date:"2023-01-05T09:07:22.013Z"}}, {id:"CVE-2023-0078", properties:{cve_id:"CVE-2023-0078", name:"Stored XSS in Resume Builder WordPress plugin", description:"The Resume Builder WordPress plugin through 3.1.1 does not sanitize and escape some parameters related to Resume, which could allow users with a role as low as subscriber to perform Stored XSS attacks against higher privilege users", created_at:datetime('2026-05-10T11:31:24.444Z'), published_date:"2023-03-06T13:34:01.157Z"}}, {id:"CVE-2023-0081", properties:{cve_id:"2023-0081", name:"MonsterInsights WordPress plugin vulnerability", description:"The MonsterInsights WordPress plugin before 8.12.1 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:31:52.487Z'), published_date:"2023-02-06T19:59:38.040Z"}}, {id:"CVE-2023-0082", properties:{cve_id:"CVE-2023-0082", name:"ExactMetrics WordPress plugin vulnerability", description:"The ExactMetrics WordPress plugin before 7.12.1 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:32:25.349Z'), updated_date:"2025-03-25T20:37:14.666Z", published_date:"2023-02-06T19:59:29.364Z"}}, {id:"CVE-2023-0080", properties:{cve_id:"CVE-2023-0080", name:"Customer Reviews for WooCommerce WordPress plugin shortcode attribute traversal attack", description:"The Customer Reviews for WooCommerce WordPress plugin before 5.16.0 does not validate one of its shortcode attribute, which could allow users with a contributor role and above to include arbitrary files via a traversal attack.", created_at:datetime('2026-05-10T11:35:28.373Z'), published_date:"2023-02-13T14:32:22.189Z"}}, {id:"cve-2023-0091", properties:{cve_id:"CVE-2023-0091", name:"Keycloak client token revocation flaw", description:"A flaw was found in Keycloak, where it did not properly check client tokens for possible revocation in its client credential flow. This flaw allows an attacker to access or modify potentially sensitive information.", created_at:datetime('2026-05-10T11:43:52.327Z'), published_date:"2023-01-11T20:44:07.553Z"}}, {id:"CVE-2023-0096", properties:{cve_id:"CVE-2023-0096", name:"Happyforms WordPress plugin vulnerability", description:"The Happyforms WordPress plugin before 1.22.0 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:44:22.023Z'), updated_date:"2025-03-25T18:05:04.183Z", published_date:"2023-02-06T19:59:39.682Z"}}, {id:"cve-2023-0094", properties:{cve_id:"CVE-2023-0094", name:"UpQode Google Maps WordPress Plugin Vulnerability", description:"The UpQode Google Maps WordPress plugin through 1.0.5 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:44:53.086Z'), updated_date:"2026-01-09T21:03:59.086Z", published_date:"2024-01-16T15:55:46.407Z"}}, {id:"cve-2023-0095", properties:{cve_id:"CVE-2023-0095", name:"Page View Count WordPress plugin vulnerability", description:"The Page View Count WordPress plugin before 2.6.1 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:45:26.907Z'), published_date:"2023-02-06T19:59:23.089Z"}}, {id:"cve-2023-0092", properties:{cvss_score:8.1, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0092", name:"Remote File Download Vulnerability in Juju Controller", created_at:datetime('2026-05-10T11:46:24.626Z'), description:"An authenticated user who has read access to the juju controller model, may construct a remote request to download an arbitrary file from the controller's filesystem.", published_date:"2025-01-31T01:41:46.439Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0097", properties:{cve_id:"CVE-2023-0097", name:"Stored Cross-Site Scripting (XSS) in Post Grid, Post Carousel, & List Category Posts WordPress plugin", description:"The Post Grid, Post Carousel, & List Category Posts WordPress plugin before 2.4.19 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T11:46:55.53Z'), published_date:"2023-01-30T20:31:47.957Z"}}, {id:"cve-2023-0093", properties:{cve_id:"CVE-2023-0093", name:"Okta Advanced Server Access Client Command Injection", description:"Okta Advanced Server Access Client versions 1.13.1 through 1.65.0 are vulnerable to command injection due to the third party library webbrowser.", created_at:datetime('2026-05-10T11:47:44.856Z'), published_date:"2023-03-06T00:00:00.000Z"}}, {id:"cve-2023-0098", properties:{cve_id:"CVE-2023-0098", name:"SQL Injection in Simple URLs WordPress Plugin", description:"The Simple URLs WordPress plugin before 115 does not escape some parameters before using them in various SQL statements used by AJAX actions available by any authenticated users, leading to a SQL injection exploitable by low privilege users such as subscriber.", created_at:datetime('2026-05-10T11:48:13.824Z'), published_date:"2023-02-13T14:32:15.988Z"}}, {id:"cve-2023-0099", properties:{cve_id:"CVE-2023-0099", name:"Reflected Cross-Site Scripting in Simple URLs WordPress plugin", description:"The Simple URLs WordPress plugin before 115 does not sanitise and escape some parameters before outputting them back in some pages, leading to Reflected Cross-Site Scripting which could be used against high privilege users such as admin.", created_at:datetime('2026-05-10T11:52:26.702Z'), published_date:"2023-02-13T14:32:05.647Z"}}, {id:"cve-2023-0105", properties:{cve_id:"CVE-2023-0105", name:"Keycloak Email Trust Flaw", created_at:datetime('2026-05-10T11:56:16.578Z'), description:"A flaw was found in Keycloak. This flaw allows impersonation and lockout due to the email trust not being handled correctly in Keycloak. An attacker can shadow other users with the same email and lockout or impersonate them.", published_date:"2023-01-11T20:46:51.617Z"}}, {id:"cve-2023-0116", properties:{cve_id:"CVE-2023-0116", name:"HarmonyOS Broadcast Authentication Vulnerability", description:"The reminder module lacks an authentication mechanism for broadcasts received. Successful exploitation of this vulnerability may affect availability.", created_at:datetime('2026-05-10T11:59:06.615Z'), published_date:"2023-05-26T00:00:00.000Z"}}, {id:"cve-2023-0117", properties:{cve_id:"CVE-2023-0117", name:"hwKitAssistant Authentication Vulnerability", description:"The online authentication provided by the hwKitAssistant lacks strict identity verification of applications.", created_at:datetime('2026-05-10T12:04:20.11Z'), published_date:"2023-05-26T00:00:00.000Z"}}, {id:"cve-2023-0127", properties:{cve_id:"CVE-2023-0127", name:"Command Injection in D-Link DWL-2600AP Firmware", description:"A command injection vulnerability in the firmware_update command, in the device's restricted telnet interface, allows an authenticated attacker to execute arbitrary commands as root.", created_at:datetime('2026-05-10T12:11:41.099Z'), published_date:"2023-02-11T00:00:00.000Z"}}, {id:"cve-2023-0130", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0130", name:"Inappropriate implementation in Fullscreen API in Google Chrome on Android prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:12:10.504Z'), description:"Inappropriate implementation in in Fullscreen API in Google Chrome on Android prior to 109.0.5414.74 allowed a remote attacker to spoof the contents of the Omnibox (URL bar) via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0128", properties:{cvss_severity:"High", cve_id:"CVE-2023-0128", name:"Use after free in Overview Mode in Google Chrome on Chrome OS prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:12:41.936Z'), description:"Use after free in Overview Mode in Google Chrome on Chrome OS prior to 109.0.5414.74 allowed a remote attacker who convinced a user to engage in specific UI interactions to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0132", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0132", name:"Inappropriate implementation in Permission prompts in Google Chrome on Windows prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:13:13.656Z'), description:"Inappropriate implementation in Permission prompts in Google Chrome on Windows prior to 109.0.5414.74 allowed a remote attacker to force acceptance of a permission prompt via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0133", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0133", name:"Inappropriate implementation in Permission prompts in Google Chrome on Android prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:13:43.225Z'), description:"Inappropriate implementation in Permission prompts in Google Chrome on Android prior to 109.0.5414.74 allowed a remote attacker to bypass main origin permission delegation via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0129", properties:{cvss_severity:"HIGH", cve_id:"CVE-2023-0129", name:"Heap buffer overflow in Network Service in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:14:12.645Z'), description:"Heap buffer overflow in Network Service in Google Chrome prior to 109.0.5414.74 allowed an attacker who convinced a user to install a malicious extension to potentially exploit heap corruption via a crafted HTML page and specific interactions.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0134", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0134", name:"Use after free in Cart in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:14:42.538Z'), description:"Use after free in Cart in Google Chrome prior to 109.0.5414.74 allowed an attacker who convinced a user to install a malicious extension to potentially exploit heap corruption via database corruption and a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0131", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0131", name:"Inappropriate implementation in iframe Sandbox in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:15:12.999Z'), description:"Inappropriate implementation in iframe Sandbox in Google Chrome prior to 109.0.5414.74 allowed a remote attacker to bypass file download restrictions via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0135", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0135", name:"Use after free in Cart in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:15:45.849Z'), description:"Use after free in Cart in Google Chrome prior to 109.0.5414.74 allowed an attacker who convinced a user to install a malicious extension to potentially exploit heap corruption via database corruption and a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0136", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0136", name:"Inappropriate implementation in Fullscreen API in Google Chrome on Android prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:16:15.721Z'), description:"Inappropriate implementation in Fullscreen API in Google Chrome on Android prior to 109.0.5414.74 allowed a remote attacker to execute incorrect security UI via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0139", properties:{cvss_severity:"Low", cve_id:"CVE-2023-0139", name:"Insufficient validation of untrusted input in Downloads in Google Chrome on Windows prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:18:36.965Z'), description:"Insufficient validation of untrusted input in Downloads in Google Chrome on Windows prior to 109.0.5414.74 allowed a remote attacker to bypass download restrictions via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}] AS row
CREATE (n:Vulnerability{id: row.id}) SET n += row.properties;
UNWIND [{id:"cve-2023-0138", properties:{cvss_severity:"LOW", cve_id:"CVE-2023-0138", name:"Heap buffer overflow in libphonenumber in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:19:09.084Z'), description:"Heap buffer overflow in libphonenumber in Google Chrome prior to 109.0.5414.74 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"CVE-2023-0144", properties:{cve_id:"CVE-2023-0144", name:"Stored Cross-Site Scripting (XSS) in WooCommerce Event Manager and Tickets Selling Plugin", description:"The Event Manager and Tickets Selling Plugin for WooCommerce WordPress plugin before 3.8.0 does not validate and escape some of its post meta before outputting them back in a page/post, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:21:15.29Z'), published_date:"2023-02-06T19:59:26.720Z"}}, {id:"cve-2023-0143", properties:{cve_id:"CVE-2023-0143", name:"Stored Cross-Site Scripting (XSS) in Send PDF for Contact Form 7 WordPress plugin", description:"The Send PDF for Contact Form 7 WordPress plugin before 0.9.9.2 does not validate and escape some of its shortcode attributes before outputting them back in the page, which could allow users with a role as low as contributor to perform Stored Cross-Site Scripting attacks which could be used against high privilege users such as admins.", created_at:datetime('2026-05-10T12:21:46.419Z'), published_date:"2023-02-06T19:59:17.384Z"}}, {id:"cve-2023-0145", properties:{cve_id:"CVE-2023-0145", name:"Saan World Clock WordPress plugin vulnerability", description:"The Saan World Clock WordPress plugin through 1.8 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:22:15.253Z'), published_date:"2023-03-20T15:52:12.480Z"}}, {id:"cve-2023-0141", properties:{cvss_severity:"Low", cve_id:"CVE-2023-0141", name:"Insufficient policy enforcement in CORS in Google Chrome prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:22:44.586Z'), description:"Insufficient policy enforcement in CORS in Google Chrome prior to 109.0.5414.74 allowed a remote attacker to leak cross-origin data via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"CVE-2023-0146", properties:{cve_id:"CVE-2023-0146", name:"Naver Map WordPress Plugin Shortcode Cross-Site Scripting Vulnerability", description:"The Naver Map WordPress plugin through 1.1.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:23:14.21Z'), updated_date:"2025-03-25T17:39:34.816Z", published_date:"2023-02-06T19:59:35.389Z"}}, {id:"cve-2023-0140", properties:{cvss_severity:"Low", cve_id:"CVE-2023-0140", name:"Inappropriate implementation in File System API in Google Chrome on Windows prior to 109.0.5414.74", created_at:datetime('2026-05-10T12:23:43.654Z'), description:"Inappropriate implementation in in File System API in Google Chrome on Windows prior to 109.0.5414.74 allowed a remote attacker to bypass file system restrictions via a crafted HTML page.", published_date:"2023-01-10T00:00:00.000Z"}}, {id:"cve-2023-0150", properties:{cve_id:"CVE-2023-0150", name:"Cloak Front End Email WordPress plugin vulnerability", description:"The Cloak Front End Email WordPress plugin before 1.9.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T12:24:15.438Z'), published_date:"2023-02-06T19:59:36.221Z"}}, {id:"CVE-2023-0151", properties:{cve_id:"CVE-2023-0151", name:"Stored Cross-Site Scripting (XSS) in uTubeVideo Gallery WordPress plugin", description:"The uTubeVideo Gallery WordPress plugin before 2.0.8 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:24:45.883Z'), published_date:"2023-02-13T14:32:22.947Z"}}, {id:"CVE-2023-0147", properties:{cve_id:"CVE-2023-0147", name:"Flexible Captcha WordPress plugin vulnerability", description:"The Flexible Captcha WordPress plugin through 4.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T12:25:15.607Z'), updated_date:"2025-03-25T19:57:39.690Z", published_date:"2023-02-06T19:59:41.302Z"}}, {id:"CVE-2023-0149", properties:{cve_id:"CVE-2023-0149", name:"WordPrezi WordPress plugin vulnerability", description:"The WordPrezi WordPress plugin before 0.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T12:25:44.899Z'), updated_date:"2025-03-25T20:36:25.062Z", published_date:"2023-02-06T19:59:30.480Z"}}, {id:"CVE-2023-0148", properties:{cve_id:"CVE-2023-0148", name:"Gallery Factory Lite WordPress plugin vulnerability", description:"The Gallery Factory Lite WordPress plugin through 2.0.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:26:14.449Z'), updated_date:"2025-03-25T18:12:10.418Z", published_date:"2023-02-06T19:59:22.291Z"}}, {id:"cve-2023-0156", properties:{cve_id:"CVE-2023-0156", name:"All-In-One Security (AIOS) WordPress plugin vulnerability", description:"The All-In-One Security (AIOS) WordPress plugin before 5.1.5 does not limit what log files to display in it's settings pages, allowing an authorized user (admin+) to view the contents of arbitrary files and list directories anywhere on the server (to which the web server has access). The plugin only displays the last 50 lines of the file.", created_at:datetime('2026-05-10T12:28:37Z'), published_date:"2023-04-10T13:17:59.914Z"}}, {id:"cve-2023-0157", properties:{cve_id:"2023-0157", name:"All-In-One Security (AIOS) WordPress plugin vulnerability", description:"The All-In-One Security (AIOS) WordPress plugin before 5.1.5 does not escape the content of log files before outputting it to the plugin admin page, allowing an authorized user (admin+) to plant bogus log files containing malicious JavaScript code that will be executed in the context of any administrator visiting this page.", created_at:datetime('2026-05-10T12:29:06.208Z'), published_date:"2023-04-10T13:18:06.543Z"}}, {id:"cve-2023-0154", properties:{cve_id:"CVE-2023-0154", name:"GamiPress WordPress plugin vulnerability", description:"The GamiPress WordPress plugin before 1.0.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:29:34.944Z'), published_date:"2023-02-06T19:59:11.729Z"}}, {id:"cve-2023-0153", properties:{cve_id:"CVE-2023-0153", name:"Stored Cross-Site Scripting (XSS) in Vimeo Video Autoplay Automute WordPress plugin", description:"The Vimeo Video Autoplay Automute WordPress plugin through 1.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:30:11.583Z'), published_date:"2023-02-06T19:59:28.523Z"}}, {id:"cve-2023-0152", properties:{cve_id:"CVE-2023-0152", name:"WP Multi Store Locator WordPress plugin vulnerability", description:"The WP Multi Store Locator WordPress plugin through 2.4 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T12:30:42.079Z'), published_date:"2023-06-05T13:39:00.208Z"}}, {id:"cve-2023-0159", properties:{cve_id:"CVE-2023-0159", name:"Extensive VC Addons for WPBakery page builder WordPress plugin vulnerability", description:"The Extensive VC Addons for WPBakery page builder WordPress plugin before 1.9.1 does not validate a parameter passed to the php extract function when loading templates, allowing an unauthenticated attacker to override the template path to read arbitrary files from the hosts file system. This may be escalated to RCE using PHP filter chains.", created_at:datetime('2026-05-10T12:32:56.514Z'), published_date:"2023-02-13T14:32:03.338Z"}}, {id:"cve-2023-0167", properties:{cve_id:"CVE-2023-0167", name:"GetResponse for WordPress plugin vulnerability", description:"The GetResponse for WordPress plugin through 5.5.31 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:36:19.435Z'), updated_date:"2025-02-26T19:04:20.927Z", published_date:"2023-03-20T15:52:17.698Z"}}, {id:"CVE-2023-0166", properties:{cvss_severity:"CRITICAL", cvss_score:8.5, cve_id:"CVE-2023-0166", name:"Stored Cross-Site Scripting (XSS) in WooCommerce Product Slider", created_at:datetime('2026-05-10T12:36:51.87Z'), description:"The Product Slider for WooCommerce by PickPlugins WordPress plugin before 1.13.42 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", published_date:"2023-02-13T14:32:20.615Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0168", properties:{cve_id:"CVE-2023-0168", name:"Olevmedia Shortcodes WordPress plugin vulnerability", description:"The Olevmedia Shortcodes WordPress plugin through 1.1.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:37:20.853Z'), published_date:"2023-02-27T15:24:33.172Z"}}, {id:"cve-2023-0165", properties:{cve_id:"CVE-2023-0165", name:"Cost Calculator WordPress plugin vulnerability", description:"The Cost Calculator WordPress plugin through 1.8 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:37:50.1Z'), updated_date:"2025-03-06T15:10:28.489Z", published_date:"2023-03-06T13:34:00.378Z"}}, {id:"cve-2023-0164", properties:{cve_id:"CVE-2023-0164", name:"OrangeScrum version 2.0.11 arbitrary command execution", description:"OrangeScrum version 2.0.11 allows an authenticated external attacker to execute arbitrary commands on the server.", created_at:datetime('2026-05-10T12:38:32.003Z'), published_date:"2023-01-18T00:00:00.000Z"}}, {id:"cve-2023-0169", properties:{cve_id:"CVE-2023-0169", name:"Zoho Forms WordPress plugin vulnerability", description:"The Zoho Forms WordPress plugin before 3.0.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:39:03.842Z'), published_date:"2023-02-13T14:32:11.933Z"}}, {id:"CVE-2023-0170", properties:{cve_id:"CVE-2023-0170", name:"Html5 Audio Player WordPress plugin vulnerability", description:"The Html5 Audio Player WordPress plugin before 2.1.12 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:39:33.145Z'), published_date:"2023-02-06T19:59:34.552Z"}}, {id:"CVE-2023-0172", properties:{cve_id:"CVE-2023-0172", name:"Juicer WordPress Plugin Vulnerability", description:"The Juicer WordPress plugin before 1.11 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T12:40:12.347Z'), updated_date:"2025-02-27T15:56:34.947Z", published_date:"2023-03-13T16:03:33.143Z"}}, {id:"CVE-2023-0173", properties:{cve_id:"CVE-2023-0173", name:"Drag & Drop Sales Funnel Builder for WordPress plugin vulnerability", description:"The Drag & Drop Sales Funnel Builder for WordPress plugin before 2.6.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:40:43.564Z'), updated_date:"2025-03-25T18:10:37.107Z", published_date:"2023-02-06T19:59:32.104Z"}}, {id:"CVE-2023-0171", properties:{cve_id:"CVE-2023-0171", name:"jQuery T(-) Countdown Widget WordPress plugin vulnerability", description:"The jQuery T(-) Countdown Widget WordPress plugin before 2.3.24 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:41:20.378Z'), updated_date:"2025-03-25T19:55:28.863Z", published_date:"2023-02-06T19:59:42.127Z"}}, {id:"CVE-2023-0175", properties:{cve_id:"CVE-2023-0175", name:"Responsive Clients Logo Gallery Plugin for WordPress plugin vulnerability", description:"The Responsive Clients Logo Gallery Plugin for WordPress plugin through 1.1.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:41:50.838Z'), updated_date:"2025-02-26T18:46:57.897Z", published_date:"2023-03-20T15:52:09.113Z"}}, {id:"cve-2023-0174", properties:{cve_id:"CVE-2023-0174", name:"WP VR Shortcode Validation Vulnerability", description:"The WP VR WordPress plugin before 8.2.7 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:42:23.58Z'), published_date:"2023-02-06T19:59:14.952Z"}}, {id:"CVE-2023-0177", properties:{cve_id:"CVE-2023-0177", name:"Social Like Box and Page by WpDevArt WordPress plugin vulnerability", description:"The Social Like Box and Page by WpDevArt WordPress plugin before 0.8.41 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:42:56.961Z'), updated_date:"2025-03-20T20:01:47.774Z", published_date:"2023-02-13T14:32:32.510Z"}}, {id:"CVE-2023-0176", properties:{cve_id:"CVE-2023-0176", name:"Giveaways and Contests by RafflePress WordPress plugin vulnerability", description:"The Giveaways and Contests by RafflePress WordPress plugin before 1.11.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:43:28.331Z'), updated_date:"2025-03-25T18:04:00.655Z", published_date:"2023-02-06T19:59:46.410Z"}}, {id:"CVE-2023-0178", properties:{cve_id:"CVE-2023-0178", name:"Annual Archive WordPress plugin vulnerability", description:"The Annual Archive WordPress plugin before 1.6.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T12:45:43.209Z'), updated_date:"2025-03-26T13:50:56.955Z", published_date:"2023-02-06T19:59:08.721Z"}}, {id:"CVE-2023-0212", properties:{cve_id:"CVE-2023-0212", name:"Stored Cross-Site Scripting (XSS) in Advanced Recent Posts plugin", description:"The Advanced Recent Posts WordPress plugin through 0.6.14 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:16:40.645Z'), published_date:"2023-03-06T13:34:03.634Z"}}, {id:"CVE-2023-0219", properties:{cve_id:"CVE-2023-0219", name:"FluentSMTP WordPress plugin vulnerability", description:"The FluentSMTP WordPress plugin before 2.2.3 does not sanitize or escape email content, making it vulnerable to stored cross-site scripting attacks (XSS) when an administrator views the email logs.", created_at:datetime('2026-05-10T13:18:14.536Z'), updated_date:"2025-02-27T15:46:50.142Z", published_date:"2023-03-13T16:03:36.376Z"}}, {id:"CVE-2023-0215", properties:{cvss_severity:"CRITICAL", cvss_score:9.8, cve_id:"CVE-2023-0215", name:"Use-after-free in BIO_new_NDEF() function", created_at:datetime('2026-05-10T13:19:43.028Z'), description:"The public API function BIO_new_NDEF is a helper function used for streaming ASN.1 data via a BIO. It is primarily used internally to OpenSSL to support the SMIME, CMS and PKCS7 streaming capabilities, but may also be called directly by end user applications.", updated_date:"2025-11-04T19:14:32.988Z", published_date:"2023-02-08T19:03:28.691Z", attack_vector:"NETWORK"}}, {id:"CVE-2023-0216", properties:{cvss_score:9.8, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0216", name:"Invalid pointer dereference on read", created_at:datetime('2026-05-10T13:21:05.391Z'), description:"An invalid pointer dereference on read can be triggered when an application tries to load malformed PKCS7 data with the d2i_PKCS7(), d2i_PKCS7_bio() or d2i_PKCS7_fp() functions.", updated_date:"2025-11-04T19:14:34.082Z", published_date:"2023-02-08T19:03:05.652Z", attack_vector:"NETWORK"}}, {id:"CVE-2023-0217", properties:{cvss_score:9.8, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0217", name:"Invalid pointer dereference on read", created_at:datetime('2026-05-10T13:21:40.481Z'), description:"An invalid pointer dereference on read can be triggered when an application tries to check a malformed DSA public key by the EVP_PKEY_public_check() function.", published_date:"2023-02-08T19:02:48.524Z", attack_vector:"NETWORK"}}, {id:"CVE-2023-0220", properties:{cve_id:"CVE-2023-0220", name:"Pinpoint Booking System WordPress plugin SQL Injection vulnerability", description:"The Pinpoint Booking System WordPress plugin before 2.9.9.2.9 does not validate and escape one of its shortcode attributes before using it in a SQL statement, which could allow any authenticated users, such as subscriber to perform SQL Injection attacks.", created_at:datetime('2026-05-10T13:22:12.359Z'), updated_date:"2025-03-21T16:21:58.259Z", published_date:"2023-02-13T14:32:08.000Z"}}, {id:"CVE-2023-0224", properties:{cve_id:"CVE-2023-0224", name:"GiveWP WordPress plugin SQL Injection vulnerability", description:"The GiveWP WordPress plugin before 2.24.1 does not properly escape user input before it reaches SQL queries, which could let unauthenticated attackers perform SQL Injection attacks", created_at:datetime('2026-05-10T13:25:54.045Z'), updated_date:"2025-06-13T16:07:48.744Z", published_date:"2024-01-16T15:54:45.597Z"}}, {id:"CVE-2023-0231", properties:{cve_id:"CVE-2023-0231", name:"ShopLentor WordPress plugin vulnerability", description:"The ShopLentor WordPress plugin before 2.5.4 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:27:24.536Z'), updated_date:"2025-03-12T16:19:50.699Z", published_date:"2023-02-21T08:50:38.876Z"}}, {id:"CVE-2023-0232", properties:{cve_id:"CVE-2023-0232", name:"PHP Object Injection in ShopLentor WordPress plugin", description:"The ShopLentor WordPress plugin before 2.5.4 unserializes user input from cookies in order to track viewed products and user data, which could lead to PHP Object Injection.", created_at:datetime('2026-05-10T13:28:42.866Z'), published_date:"2023-02-21T08:51:02.165Z"}}, {id:"CVE-2023-0230", properties:{cve_id:"CVE-2023-0230", name:"VK All in One Expansion Unit WordPress plugin vulnerability", description:"The VK All in One Expansion Unit WordPress plugin before 9.86.0.0 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:29:45.202Z'), updated_date:"2025-03-10T18:07:43.646Z", published_date:"2023-02-27T15:24:26.720Z"}}, {id:"cve-2023-0234", properties:{cve_id:"CVE-2023-0234", name:"Authenticated SQL Injection in SiteGround Security WordPress Plugin", description:"The SiteGround Security WordPress plugin before 1.3.1 does not properly sanitize user input before using it in an SQL query, leading to an authenticated SQL injection issue.", created_at:datetime('2026-05-10T13:30:13.207Z'), updated_date:"2025-03-25T18:09:53.520Z", published_date:"2023-02-06T19:59:32.911Z"}}, {id:"CVE-2023-0233", properties:{cve_id:"CVE-2023-0233", name:"Stored Cross-Site Scripting in ActiveCampaign WordPress Plugin", description:"The ActiveCampaign WordPress plugin before 8.1.12 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T13:30:44.617Z'), published_date:"2023-05-15T12:15:47.088Z"}}, {id:"cve-2023-0236", properties:{cve_id:"2023-0236", name:"Reflected Cross-Site Scripting in Tutor LMS WordPress plugin", description:"The Tutor LMS WordPress plugin before 2.0.10 does not sanitise and escape the reset_key and user_id parameters before outputting then back in attributes, leading to Reflected Cross-Site Scripting which could be used against high privilege users such as admin", created_at:datetime('2026-05-10T13:31:16.31Z'), published_date:"2023-02-06T19:59:21.460Z"}}, {id:"CVE-2023-0252", properties:{cve_id:"CVE-2023-0252", name:"Contextual Related Posts WordPress plugin vulnerability", description:"The Contextual Related Posts WordPress plugin before 3.3.1 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T13:42:15.239Z'), updated_date:"2025-03-25T17:38:13.714Z", published_date:"2023-02-06T19:59:49.263Z"}}, {id:"CVE-2023-0255", properties:{cve_id:"CVE-2023-0255", name:"Enable Media Replace WordPress plugin arbitrary file upload vulnerability", description:"The Enable Media Replace WordPress plugin before 4.0.2 does not prevent authors from uploading arbitrary files to the site, which may allow them to upload PHP shells on affected sites.", created_at:datetime('2026-05-10T13:44:43.921Z'), published_date:"2023-02-13T14:32:21.404Z"}}, {id:"cve-2023-0259", properties:{cve_id:"CVE-2023-0259", name:"WP Google Review Slider WordPress plugin SQL injection vulnerability", description:"The WP Google Review Slider WordPress plugin before 11.8 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by users with a role as low as subscriber.", created_at:datetime('2026-05-10T13:48:33.869Z'), published_date:"2023-02-13T14:32:19.847Z"}}, {id:"cve-2023-0261", properties:{cve_id:"CVE-2023-0261", name:"WP TripAdvisor Review Slider WordPress plugin SQL injection vulnerability", description:"The WP TripAdvisor Review Slider WordPress plugin before 10.8 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by users with a role as low as subscriber.", created_at:datetime('2026-05-10T13:49:04.769Z'), published_date:"2023-02-13T14:32:10.388Z"}}, {id:"cve-2023-0264", properties:{cve_id:"CVE-2023-0264", name:"Keycloak OpenID Connect User Authentication Flaw", description:"A flaw was found in Keycloaks OpenID Connect user authentication, which may incorrectly authenticate requests. An authenticated attacker who could obtain information from a user request within the same realm could use that data to impersonate the victim and generate new session tokens. This issue could impact confidentiality, integrity, and availability.", created_at:datetime('2026-05-10T13:49:37.248Z'), published_date:"2023-08-04T17:09:27.693Z"}}, {id:"cve-2023-0263", properties:{cve_id:"2023-0263", name:"WP Yelp Review Slider WordPress plugin SQL injection vulnerability", description:"The WP Yelp Review Slider WordPress plugin before 7.1 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by users with a role as low as subscriber.", created_at:datetime('2026-05-10T13:50:06.957Z'), published_date:"2023-02-13T14:32:17.532Z"}}, {id:"CVE-2023-0260", properties:{cve_id:"CVE-2023-0260", name:"WP Review Slider WordPress plugin SQL injection vulnerability", description:"The WP Review Slider WordPress plugin before 12.2 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by users with a role as low as subscriber.", created_at:datetime('2026-05-10T13:50:34.679Z'), published_date:"2023-02-13T14:32:12.713Z"}}, {id:"CVE-2023-0262", properties:{cve_id:"CVE-2023-0262", name:"WP Airbnb Review Slider WordPress plugin SQL injection vulnerability", description:"The WP Airbnb Review Slider WordPress plugin before 3.3 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by users with a role as low as subscriber.", created_at:datetime('2026-05-10T13:51:03.395Z'), published_date:"2023-02-13T14:32:28.589Z"}}, {id:"CVE-2023-0267", properties:{cve_id:"CVE-2023-0267", name:"Stored Cross-Site Scripting (XSS) in Ultimate Carousel For WPBakery Page Builder", description:"The Ultimate Carousel For WPBakery Page Builder WordPress plugin through 2.6 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:51:35.394Z'), published_date:"2023-05-08T13:58:02.805Z"}}, {id:"CVE-2023-0268", properties:{cve_id:"CVE-2023-0268", name:"Mega Addons For WPBakery Page Builder WordPress plugin vulnerability", description:"The Mega Addons For WPBakery Page Builder WordPress plugin before 4.3.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:52:11.889Z'), updated_date:"2025-01-28T21:09:03.212Z", published_date:"2023-05-08T13:58:25.619Z"}}, {id:"cve-2023-0265", properties:{cve_id:"CVE-2023-0265", name:"Uvdesk version 1.1.1 remote command execution vulnerability", description:"Uvdesk version 1.1.1 allows an authenticated remote attacker to execute commands on the server.", created_at:datetime('2026-05-10T13:53:35.881Z'), published_date:"2023-04-04T00:00:00.000Z", status:"published"}}, {id:"CVE-2023-0271", properties:{cve_id:"CVE-2023-0271", name:"WP Font Awesome WordPress plugin vulnerability", description:"The WP Font Awesome WordPress plugin before 1.7.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embedded, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:54:03.973Z'), published_date:"2023-02-21T08:50:36.488Z"}}, {id:"cve-2023-0270", properties:{cve_id:"CVE-2023-0270", name:"Stored Cross-Site Scripting (XSS) in YaMaps for WordPress Plugin", description:"The YaMaps for WordPress Plugin WordPress plugin before 0.6.26 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:54:33.594Z'), published_date:"2023-02-13T14:32:02.489Z"}}, {id:"CVE-2023-0273", properties:{cve_id:"CVE-2023-0273", name:"Custom Content Shortcode WordPress plugin vulnerability", description:"The Custom Content Shortcode WordPress plugin through 4.0.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T13:55:10.173Z'), published_date:"2023-03-20T15:52:21.047Z"}}, {id:"CVE-2023-0272", properties:{cve_id:"CVE-2023-0272", name:"NEX-Forms WordPress plugin vulnerability", description:"The NEX-Forms WordPress plugin before 8.3.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T13:55:41.298Z'), updated_date:"2025-02-19T16:01:14.072Z", published_date:"2023-03-27T15:37:41.482Z"}}, {id:"CVE-2023-0276", properties:{cve_id:"CVE-2023-0276", name:"Stored Cross-Site Scripting (XSS) in Weaver Xtreme Theme Support plugin", description:"The Weaver Xtreme Theme Support WordPress plugin before 6.2.7 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:56:11.806Z'), published_date:"2023-04-24T18:30:53.152Z"}}, {id:"CVE-2023-0274", properties:{cve_id:"CVE-2023-0274", name:"Stored Cross-Site Scripting (XSS) in URL Params WordPress plugin", description:"The URL Params WordPress plugin before 2.5 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:56:40.05Z'), published_date:"2023-08-16T11:03:26.919Z"}}, {id:"cve-2023-0275", properties:{cve_id:"CVE-2023-0275", name:"Easy Accept Payments for PayPal WordPress plugin vulnerability", description:"The Easy Accept Payments for PayPal WordPress plugin before 4.9.10 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:57:10.677Z'), updated_date:"2025-03-21T15:27:24.754Z", published_date:"2023-02-13T14:32:18.294Z"}}, {id:"CVE-2023-0282", properties:{cve_id:"CVE-2023-0282", name:"Cross-Site Scripting (XSS) in YourChannel WordPress plugin", description:"The YourChannel WordPress plugin before 1.2.2 does not sanitize and escape some parameters, which could allow users with a role as low as Subscriber to perform Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:57:39.021Z'), published_date:"2023-02-06T19:59:24.802Z"}}, {id:"CVE-2023-0280", properties:{cve_id:"CVE-2023-0280", name:"Stored Cross-Site Scripting (XSS) in Ultimate Carousel For Elementor plugin", description:"The Ultimate Carousel For Elementor plugin through 2.1.7 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T13:58:08.466Z'), published_date:"2023-05-08T13:58:17.650Z"}}, {id:"CVE-2023-0277", properties:{cve_id:"CVE-2023-0277", name:"WC Fields Factory WordPress plugin SQL injection vulnerability", description:"The WC Fields Factory WordPress plugin through 4.1.5 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by high privilege users such as admin", created_at:datetime('2026-05-10T13:58:38.192Z'), published_date:"2023-04-17T12:17:40.775Z"}}, {id:"cve-2023-0278", properties:{cve_id:"CVE-2023-0278", name:"GeoDirectory WordPress plugin SQL injection vulnerability", description:"The GeoDirectory WordPress plugin before 2.2.24 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by high privilege users such as admin.", created_at:datetime('2026-05-10T13:59:07.993Z'), published_date:"2023-02-27T15:24:40.738Z"}}, {id:"CVE-2023-0279", properties:{cve_id:"CVE-2023-0279", name:"Media Library Assistant WordPress plugin vulnerability", description:"The Media Library Assistant WordPress plugin before 3.06 does not properly sanitise and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by high privilege users such as admin.", created_at:datetime('2026-05-10T14:02:00.878Z'), updated_date:"2025-03-10T18:13:40.797Z", published_date:"2023-02-27T15:24:39.076Z"}}, {id:"CVE-2023-0285", properties:{cve_id:"CVE-2023-0285", name:"Stored Cross-Site Scripting (XSS) in Real Media Library WordPress plugin", description:"The Real Media Library WordPress plugin before 4.18.29 does not sanitise and escape the created folder names, which could allow users with the role of author and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T14:02:54.013Z'), published_date:"2023-02-21T08:50:42.950Z"}}, {id:"cve-2023-0325", properties:{cve_id:"CVE-2023-0325", name:"Uvdesk Stored XSS", created_at:datetime('2026-05-10T14:40:07.885Z'), description:"Uvdesk version 1.1.1 allows an unauthenticated remote attacker to exploit a stored XSS in the application. This is possible because the application does not correctly validate the message sent by the clients in the ticket.", published_date:"2023-04-04T00:00:00.000Z"}}, {id:"cve-2023-0326", properties:{cve_id:"CVE-2023-0326", name:"GitLab DAST API scanner Authorization header leak", description:"An issue has been discovered in GitLab DAST API scanner affecting all versions starting from 1.6.50 before 2.11.0, where Authorization headers was leaked in vulnerability report evidence.", created_at:datetime('2026-05-10T14:41:17.528Z'), published_date:"2023-03-27T00:00:00.000Z"}}, {id:"cve-2023-0329", properties:{cvss_score:8.5, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0329", name:"SQL Injection in Elementor Website Builder", created_at:datetime('2026-05-10T14:42:21.755Z'), description:"The Elementor Website Builder WordPress plugin before 3.12.2 does not properly sanitize and escape the Replace URL parameter in the Tools module before using it in a SQL statement, leading to a SQL injection exploitable by users with the Administrator role.", published_date:"2023-05-30T07:49:13.896Z", attack_vector:"NETWORK"}}, {id:"CVE-2023-0331", properties:{cve_id:"CVE-2023-0331", name:"Correos Oficial WordPress plugin vulnerability", description:"The Correos Oficial WordPress plugin through 1.2.0.2 does not have an authorization check user input validation when generating a file path, allowing unauthenticated attackers to download arbitrary files from the server.", created_at:datetime('2026-05-10T14:42:50.105Z'), updated_date:"2025-03-10T18:17:19.090Z", published_date:"2023-02-27T15:24:42.395Z"}}, {id:"CVE-2023-0328", properties:{cve_id:"CVE-2023-0328", name:"WPCode WordPress plugin privilege check vulnerability", description:"The WPCode WordPress plugin before 2.0.7 does not have adequate privilege checks in place for several AJAX actions, only checking the nonce. This may lead to allowing any authenticated user who can edit posts to call the endpoints related to WPCode Library authentication (such as update and delete the auth key).", created_at:datetime('2026-05-10T14:43:56.211Z'), published_date:"2023-03-06T13:33:58.773Z"}}, {id:"CVE-2023-0335", properties:{cve_id:"CVE-2023-0335", name:"WP Shamsi WordPress plugin vulnerability", description:"The WP Shamsi WordPress plugin through 4.3.3 has CSRF and broken access control vulnerabilities which leads user with role as low as subscriber delete attachment.", created_at:datetime('2026-05-10T14:44:32.271Z'), updated_date:"2025-02-19T20:19:09.595Z", published_date:"2023-03-27T15:37:21.384Z"}}, {id:"cve-2023-0334", properties:{cve_id:"CVE-2023-0334", name:"ShortPixel Adaptive Images WordPress plugin vulnerability", description:"The ShortPixel Adaptive Images WordPress plugin before 3.6.3 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against any high privilege users such as admin", created_at:datetime('2026-05-10T14:45:00.528Z'), published_date:"2023-02-27T15:24:25.925Z"}}, {id:"CVE-2023-0333", properties:{cve_id:"CVE-2023-0333", name:"TemplatesNext ToolKit WordPress plugin vulnerability", description:"The TemplatesNext ToolKit WordPress plugin before 3.2.9 does not validate some of its shortcode attributes before using them to generate an HTML tag, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T14:45:29.913Z'), updated_date:"2025-03-21T16:14:13.520Z", published_date:"2023-02-13T14:32:14.358Z"}}, {id:"cve-2023-0336", properties:{cve_id:"CVE-2023-0336", name:"OoohBoi Steroids for Elementor WordPress plugin vulnerability", description:"The OoohBoi Steroids for Elementor WordPress plugin before 2.1.5 has CSRF and broken access control vulnerabilities which leads user with role as low as subscriber to delete attachment.", created_at:datetime('2026-05-10T14:46:41.652Z'), updated_date:"2025-02-19T19:27:21.170Z", published_date:"2023-03-27T15:37:38.218Z"}}, {id:"cve-2023-0340", properties:{cve_id:"CVE-2023-0340", name:"Custom Content Shortcode WordPress plugin vulnerability", description:"The Custom Content Shortcode WordPress plugin through 4.0.2 does not validate one of its shortcode attribute, which could allow users with a contributor role and above to include arbitrary files via a traversal attack.", created_at:datetime('2026-05-10T14:47:59.862Z'), published_date:"2023-03-20T15:52:22.788Z"}}, {id:"cve-2023-0343", properties:{cve_id:"CVE-2023-0343", name:"Akuvox E11 Message Encryption Vulnerability", description:"Akuvox E11 contains a function that encrypts messages which are then forwarded. The IV vector and the key are static, and this may allow an attacker to decrypt messages.", created_at:datetime('2026-05-10T14:50:01.99Z'), updated_date:"2025-01-16T21:37:18.422Z", published_date:"2023-03-31T15:42:22.858Z"}}, {id:"cve-2023-0344", properties:{cve_id:"CVE-2023-0344", name:"Insecure SSH Server in Akuvox E11", created_at:datetime('2026-05-10T14:50:29.842Z'), description:"Akuvox E11 appears to be using a custom version of dropbear SSH server. This server allows an insecure option that by default is not in the official dropbear SSH server.", published_date:"2023-03-31T15:43:23.608Z"}}, {id:"cve-2023-0349", properties:{cve_id:"CVE-2023-0349", name:"Unauthenticated camera access in Akuvox E11 libvoice library", description:"The Akuvox E11 libvoice library provides unauthenticated access to the camera capture for image and video. This could allow an attacker to view and record image and video from the camera.", created_at:datetime('2026-05-10T14:52:11.721Z'), published_date:"2023-03-13T20:23:34.393Z"}}, {id:"cve-2023-0346", properties:{cve_id:"CVE-2023-0346", name:"Akuvox E11 cloud login vulnerability", created_at:datetime('2026-05-10T14:52:39.423Z'), description:"Akuvox E11 cloud login is performed through an unencrypted HTTP connection. An attacker could gain access to the Akuvox cloud and device if the MAC address of a device if known.", published_date:"2023-03-13T20:28:00.701Z"}}, {id:"cve-2023-0347", properties:{cve_id:"CVE-2023-0347", name:"Akuvox E11 MAC Address and IP Address Identification Vulnerability", description:"The Akuvox E11 Media Access Control (MAC) address, a primary identifier, combined with the Akuvox E11 IP address, could allow an attacker to identify the device on the Akuvox cloud.", created_at:datetime('2026-05-10T14:53:09.021Z'), published_date:"2023-03-13T20:27:02.285Z"}}, {id:"cve-2023-0345", properties:{cve_id:"CVE-2023-0345", name:"Akuvox E11 SSH Server Default Password", description:"The Akuvox E11 secure shell (SSH) server is enabled by default and can be accessed by the root user. This password cannot be changed by the user.", created_at:datetime('2026-05-10T14:53:36.783Z'), published_date:"2023-03-13T20:29:30.386Z"}}, {id:"cve-2023-0348", properties:{cve_id:"CVE-2023-0348", name:"Akuvox E11 allows direct SIP calls", created_at:datetime('2026-05-10T14:54:04.457Z'), description:"Akuvox E11 allows direct SIP calls. No access control is enforced by the SIP servers, which could allow an attacker to contact any device within Akuvox to call any other device.", published_date:"2023-03-13T20:24:11.414Z"}}, {id:"cve-2023-0353", properties:{cve_id:"CVE-2023-0353", name:"Akuvox E11 Password Encryption Vulnerability", description:"Akuvox E11 uses a weak encryption algorithm for stored passwords and uses a hard-coded password for decryption which could allow the encrypted passwords to be decrypted from the configuration file.", created_at:datetime('2026-05-10T14:54:36.743Z'), updated_date:"2025-01-16T21:45:17.644Z", published_date:"2023-03-13T20:07:22.716Z"}}, {id:"cve-2023-0350", properties:{cve_id:"CVE-2023-0350", name:"Akuvox E11 File Extension Association Vulnerability", description:"Akuvox E11 does not ensure that a file extension is associated with the file provided. This could allow an attacker to upload a file to the device by changing the extension of a malicious file to an accepted file type.", created_at:datetime('2026-05-10T14:55:04.599Z'), published_date:"2023-03-13T20:22:53.970Z"}}, {id:"cve-2023-0352", properties:{cve_id:"CVE-2023-0352", name:"Akuvox E11 Password Recovery Webpage Vulnerability", description:"The Akuvox E11 password recovery webpage can be accessed without authentication, and an attacker could download the device key file. An attacker could then use this page to reset the password back to the default.", created_at:datetime('2026-05-10T14:55:32.474Z'), published_date:"2023-03-13T20:15:51.389Z"}}, {id:"cve-2023-0351", properties:{cve_id:"CVE-2023-0351", name:"Akuvox E11 Web Server Backend Library Command Injection", description:"The Akuvox E11 web server backend library allows command injection in the device phone-book contacts functionality. This could allow an attacker to upload files with executable command instructions.", created_at:datetime('2026-05-10T14:56:34.434Z'), published_date:"2023-03-13T20:22:01.322Z"}}, {id:"cve-2023-0355", properties:{cve_id:"CVE-2023-0355", name:"Hard-coded cryptographic key in Akuvox E11", description:"Akuvox E11 uses a hard-coded cryptographic key, which could allow an attacker to decrypt sensitive information.", created_at:datetime('2026-05-10T14:57:00.863Z'), published_date:"2023-03-13T19:57:47.690Z"}}, {id:"cve-2023-0354", properties:{cve_id:"CVE-2023-0354", name:"Akuvox E11 Web Server Vulnerability", created_at:datetime('2026-05-10T14:57:28.325Z'), description:"The Akuvox E11 web server can be accessed without any user authentication, and this could allow an attacker to access sensitive information, as well as create and download packet captures with known default URLs.", published_date:"2023-03-13T20:04:43.540Z"}}, {id:"cve-2023-0360", properties:{cve_id:"CVE-2023-0360", name:"Location Weather WordPress plugin vulnerability", description:"The Location Weather WordPress plugin before 1.3.4 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T14:58:36.649Z'), published_date:"2023-02-13T14:32:33.325Z"}}, {id:"cve-2023-0357", properties:{cve_id:"CVE-2023-0357", name:"Helpy version 2.8.0 XSS vulnerability", description:"Helpy version 2.8.0 allows an unauthenticated remote attacker to exploit an XSS stored in the application.", created_at:datetime('2026-05-10T14:59:06.651Z'), published_date:"2023-04-04T00:00:00.000Z"}}, {id:"cve-2023-0361", properties:{cvss_score:9.8, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0361", name:"Timing side-channel in GnuTLS ClientKeyExchange messages", created_at:datetime('2026-05-10T15:00:25.914Z'), description:"A timing side-channel in the handling of RSA ClientKeyExchange messages was discovered in GnuTLS.", updated_date:"2025-03-19T17:45:36.732Z", published_date:"2023-02-15T00:00:00.000Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0364", properties:{cve_id:"CVE-2023-0364", name:"Stored Cross-Site Scripting (XSS) in real.Kit WordPress plugin", description:"The real.Kit WordPress plugin before 5.1.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:00:54.508Z'), published_date:"2023-03-20T15:52:14.304Z"}}, {id:"CVE-2023-0363", properties:{cve_id:"CVE-2023-0363", name:"Scheduled Announcements Widget WordPress plugin vulnerability", description:"The Scheduled Announcements Widget WordPress plugin before 1.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:01:26.092Z'), updated_date:"2025-02-11T15:18:37.845Z", published_date:"2023-04-10T13:17:52.212Z"}}, {id:"cve-2023-0367", properties:{cve_id:"CVE-2023-0367", name:"Pricing Tables For WPBakery Page Builder (formerly Visual Composer) WordPress plugin vulnerability", description:"The Pricing Tables For WPBakery Page Builder (formerly Visual Composer) WordPress plugin before 3.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:02:04.129Z'), published_date:"2023-04-17T12:17:44.774Z"}}, {id:"cve-2023-0362", properties:{cve_id:"CVE-2023-0362", name:"Themify Portfolio Post WordPress plugin vulnerability", description:"Themify Portfolio Post WordPress plugin before 1.2.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:02:33.933Z'), published_date:"2023-02-13T14:32:01.690Z"}}] AS row
CREATE (n:Vulnerability{id: row.id}) SET n += row.properties;
UNWIND [{id:"CVE-2023-0366", properties:{cve_id:"CVE-2023-0366", name:"Stored Cross-Site Scripting (XSS) in Loan Comparison WordPress plugin", description:"The Loan Comparison WordPress plugin before 1.5.3 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:03:02.425Z'), published_date:"2023-02-21T08:50:59.725Z"}}, {id:"CVE-2023-0365", properties:{cve_id:"CVE-2023-0365", name:"Stored Cross-Site Scripting (XSS) in React Webcam WordPress plugin", description:"The React Webcam WordPress plugin through 1.2.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:03:30.731Z'), published_date:"2023-03-20T15:52:09.937Z"}}, {id:"CVE-2023-0368", properties:{cve_id:"CVE-2023-0368", name:"Stored Cross-Site Scripting (XSS) in Responsive Tabs For WPBakery Page Builder", description:"The Responsive Tabs For WPBakery Page Builder (formerly Visual Composer) WordPress plugin through 1.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:04:06.8Z'), published_date:"2023-06-19T10:52:48.139Z"}}, {id:"CVE-2023-0371", properties:{cve_id:"CVE-2023-0371", name:"EmbedSocial WordPress plugin vulnerability", description:"The EmbedSocial WordPress plugin before 1.1.28 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:04:39.402Z'), updated_date:"2025-03-13T20:02:26.271Z", published_date:"2023-02-21T08:50:52.506Z"}}, {id:"CVE-2023-0369", properties:{cve_id:"CVE-2023-0369", name:"GoToWP WordPress plugin vulnerability", description:"The GoToWP WordPress plugin through 5.1.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:05:10.544Z'), updated_date:"2025-02-26T14:41:57.819Z", published_date:"2023-03-20T15:52:11.669Z"}}, {id:"CVE-2023-0372", properties:{cve_id:"CVE-2023-0372", name:"EmbedStories WordPress plugin vulnerability", description:"The EmbedStories WordPress plugin before 0.7.5 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:05:42.364Z'), updated_date:"2025-03-14T14:25:10.980Z", published_date:"2023-02-21T08:50:49.266Z"}}, {id:"CVE-2023-0370", properties:{cve_id:"CVE-2023-0370", name:"WPB Advanced FAQ WordPress plugin vulnerability", description:"The WPB Advanced FAQ WordPress plugin through 1.0.6 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:06:12.29Z'), updated_date:"2025-02-26T19:02:39.171Z", published_date:"2023-03-20T15:52:19.368Z"}}, {id:"cve-2023-0373", properties:{cve_id:"CVE-2023-0373", name:"Stored Cross-Site Scripting (XSS) in Lightweight Accordion WordPress plugin", description:"The Lightweight Accordion WordPress plugin before 1.5.15 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:06:41.646Z'), published_date:"2023-02-13T14:32:09.595Z"}}, {id:"cve-2023-0377", properties:{cve_id:"CVE-2023-0377", name:"Scriptless Social Sharing WordPress plugin vulnerability", description:"The Scriptless Social Sharing WordPress plugin before 3.2.2 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:07:10.567Z'), published_date:"2023-03-06T13:34:05.264Z"}}, {id:"CVE-2023-0378", properties:{cve_id:"CVE-2023-0378", name:"Stored Cross-Site Scripting (XSS) in Greenshift WordPress plugin", description:"The Greenshift WordPress plugin before 5.0 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:07:42.262Z'), updated_date:"2025-03-12T20:30:26.024Z", published_date:"2023-02-21T08:50:43.727Z"}}, {id:"CVE-2023-0376", properties:{cve_id:"CVE-2023-0376", name:"Qubely WordPress plugin vulnerability", description:"The Qubely WordPress plugin before 1.8.5 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:08:19.595Z'), updated_date:"2025-06-02T15:09:50.638Z", published_date:"2024-01-16T15:55:51.086Z"}}, {id:"CVE-2023-0379", properties:{cve_id:"2023-0379", name:"Stored Cross-Site Scripting (XSS) in Spotlight Social Feeds WordPress plugin", description:"The Spotlight Social Feeds WordPress plugin before 1.4.3 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:08:52.706Z'), published_date:"2023-02-13T14:31:59.320Z"}}, {id:"cve-2023-0375", properties:{cve_id:"CVE-2023-0375", name:"Easy Affiliate Links WordPress plugin vulnerability", description:"The Easy Affiliate Links WordPress plugin before 3.7.1 does not validate and escape some of its block options before outputting them back in a page/post where the block is embedded, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:09:22.581Z'), updated_date:"2025-03-12T20:32:20.521Z", published_date:"2023-02-21T08:50:38.098Z"}}, {id:"cve-2023-0380", properties:{cve_id:"CVE-2023-0380", name:"Easy Digital Downloads WordPress plugin vulnerability", description:"The Easy Digital Downloads WordPress plugin before 3.1.0.5 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:09:51.353Z'), published_date:"2023-02-21T08:50:35.659Z"}}, {id:"CVE-2023-0374", properties:{cve_id:"CVE-2023-0374", name:"W4 Post List WordPress plugin vulnerability", description:"The W4 Post List WordPress plugin before 2.4.6 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:10:21.291Z'), updated_date:"2025-02-06T16:25:48.981Z", published_date:"2023-04-17T12:17:38.355Z"}}, {id:"CVE-2023-0381", properties:{cve_id:"CVE-2023-0381", name:"GigPress WordPress Plugin SQL Injection Vulnerability", description:"The GigPress WordPress plugin through 2.3.28 does not validate and escape some of its shortcode attributes before using them in SQL statement/s, which could allow any authenticated users, such as subscriber to perform SQL Injection attacks", created_at:datetime('2026-05-10T15:12:52.124Z'), published_date:"2023-02-27T15:24:32.174Z"}}, {id:"CVE-2023-0388", properties:{cve_id:"CVE-2023-0388", name:"SQL Injection in Random Text WordPress Plugin", description:"The Random Text WordPress plugin through 0.3.0 does not properly sanitize and escape a parameter before using it in a SQL statement, leading to a SQL injection exploitable by any authenticated users, such as subscribers.", created_at:datetime('2026-05-10T15:14:40.477Z'), updated_date:"2025-02-04T18:33:41.863Z", published_date:"2023-04-24T18:30:54.683Z"}}, {id:"cve-2023-0389", properties:{cve_id:"CVE-2023-0389", name:"Stored Cross-Site Scripting (XSS) in Calculated Fields Form WordPress plugin", description:"The Calculated Fields Form WordPress plugin before 1.1.151 does not sanitise and escape some of its form settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup)", created_at:datetime('2026-05-10T15:16:36.153Z'), published_date:"2024-01-16T15:56:07.623Z"}}, {id:"CVE-2023-0399", properties:{cve_id:"CVE-2023-0399", name:"Image Over Image For WPBakery Page Builder WordPress plugin vulnerability", description:"The Image Over Image For WPBakery Page Builder WordPress plugin before 3.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:19:33.598Z'), updated_date:"2025-02-14T19:18:27.612Z", published_date:"2023-04-03T14:38:29.299Z"}}, {id:"CVE-2023-0395", properties:{cve_id:"CVE-2023-0395", name:"WordPress Menu Shortcode Vulnerability", description:"The menu shortcode WordPress plugin through 1.0 does not validate and escape some of its block options before outputting them back in a page/post where the block is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:20:03.907Z'), updated_date:"2025-02-19T15:11:34.491Z", published_date:"2023-03-27T15:37:46.234Z"}}, {id:"CVE-2023-0401", properties:{cvss_score:9.8, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0401", name:"NULL Pointer Dereference in OpenSSL", created_at:datetime('2026-05-10T15:23:31.729Z'), description:"A NULL pointer can be dereferenced when signatures are being verified on PKCS7 signed or signedAndEnveloped data.", published_date:"2023-02-08T19:00:53.435Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0405", properties:{cve_id:"CVE-2023-0405", name:"GPT AI Power: Content Writer & ChatGPT & Image Generator & WooCommerce Product Writer & AI Training WordPress plugin vulnerability", description:"The GPT AI Power: Content Writer & ChatGPT & Image Generator & WooCommerce Product Writer & AI Training WordPress plugin before 1.4.38 does not perform any kind of nonce or privilege checks before letting logged-in users modify arbitrary posts.", created_at:datetime('2026-05-10T15:26:46.642Z'), published_date:"2023-02-13T14:32:23.773Z"}}, {id:"cve-2023-0411", properties:{cve_id:"CVE-2023-0411", name:"Excessive loops in multiple dissectors in Wireshark", description:"Excessive loops in multiple dissectors in Wireshark 4.0.0 to 4.0.2 and 3.6.0 to 3.6.10 and allows denial of service via packet injection or crafted capture file", created_at:datetime('2026-05-10T15:27:49.281Z'), published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0417", properties:{cve_id:"CVE-2023-0417", name:"Memory leak in the NFS dissector in Wireshark", description:"Memory leak in the NFS dissector in Wireshark 4.0.0 to 4.0.2 and 3.6.0 to 3.6.10 and allows denial of service via packet injection or crafted capture file", created_at:datetime('2026-05-10T15:34:32.783Z'), published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0419", properties:{cve_id:"CVE-2023-0419", name:"Shortcode for Font Awesome WordPress plugin vulnerability", description:"The Shortcode for Font Awesome WordPress plugin before 1.4.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embedded, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T15:36:58.518Z'), updated_date:"2025-03-12T15:20:25.781Z", published_date:"2023-02-21T08:51:05.416Z"}}, {id:"CVE-2023-0421", properties:{cve_id:"CVE-2023-0421", name:"Cloud Manager WordPress Plugin XSS Vulnerability", description:"The Cloud Manager WordPress plugin through 1.0 does not sanitise and escape the query param ricerca before outputting it in an admin panel, allowing unauthenticated attackers to trick a logged in admin to trigger a XSS payload by clicking a link.", created_at:datetime('2026-05-10T15:37:27.609Z'), updated_date:"2025-05-05T16:09:09.983Z", published_date:"2023-05-08T13:58:04.382Z"}}, {id:"CVE-2023-0418", properties:{cve_id:"CVE-2023-0418", name:"Stored Cross-Site Scripting (XSS) in Video Central for WordPress plugin", description:"The Video Central for WordPress plugin through 1.3.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:37:56.371Z'), published_date:"2023-04-24T18:31:00.385Z"}}, {id:"CVE-2023-0420", properties:{cve_id:"CVE-2023-0420", name:"Stored Cross-Site Scripting (XSS) via CSRF in Custom Post Type and Taxonomy GUI Manager WordPress plugin", description:"The Custom Post Type and Taxonomy GUI Manager WordPress plugin through 1.1 does not have CSRF, and is lacking sanitising as well as escaping in some parameters, allowing attackers to make a logged in admin put Stored Cross-Site Scripting payloads via CSRF", created_at:datetime('2026-05-10T15:38:28.909Z'), published_date:"2023-04-24T18:30:49.071Z"}}, {id:"cve-2023-0423", properties:{cve_id:"2023-0423", name:"WordPress Amazon S3 Plugin Reflected Cross-Site Scripting", description:"The WordPress Amazon S3 Plugin WordPress plugin before 1.6 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high privilege users such as admin", created_at:datetime('2026-05-10T15:40:49.672Z'), published_date:"2023-04-10T13:18:02.898Z"}}, {id:"cve-2023-0424", properties:{cve_id:"2023-0424", name:"MS-Reviews WordPress Plugin Vulnerability", description:"The MS-Reviews WordPress plugin through 1.5 does not sanitise and escape reviews, which could allow users any authenticated users, such as Subscribers to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T15:42:11.699Z'), published_date:"2023-04-24T18:30:57.743Z"}}, {id:"CVE-2023-0422", properties:{cve_id:"CVE-2023-0422", name:"Article Directory WordPress plugin Stored XSS vulnerability", description:"The Article Directory WordPress plugin through 1.3 does not properly sanitize the `publish_terms_text` setting before displaying it in the administration panel, which may enable administrators to conduct Stored XSS attacks in multisite contexts.", created_at:datetime('2026-05-10T15:43:41.021Z'), published_date:"2023-04-10T13:18:01.633Z"}}, {id:"cve-2023-0431", properties:{cve_id:"CVE-2023-0431", name:"Stored Cross-Site Scripting (XSS) in File Away WordPress plugin", description:"The File Away WordPress plugin through 3.9.9.0.1 does not validate and escape one of its shortcode attributes, which could allow users with a role as low as contributor to perform Stored Cross-Site Scripting attack.", created_at:datetime('2026-05-10T15:44:11.085Z'), published_date:"2023-06-12T17:28:21.850Z"}}, {id:"cve-2023-0428", properties:{cve_id:"CVE-2023-0428", name:"Reflected Cross-Site Scripting in Watu Quiz WordPress plugin", description:"The Watu Quiz WordPress plugin before 3.3.8.2 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high privilege users such as admin.", created_at:datetime('2026-05-10T15:45:17.02Z'), updated_date:"2025-03-12T20:26:43.909Z", published_date:"2023-02-21T08:50:56.586Z"}}, {id:"cve-2023-0430", properties:{cve_id:"CVE-2023-0430", name:"Certificate OCSP revocation status not checked when verifying S/Mime signatures", description:"Mail signed with a revoked certificate would be displayed as having a valid signature.", created_at:datetime('2026-05-10T15:46:09.934Z'), published_date:"2023-06-02T00:00:00.000Z"}}, {id:"cve-2023-0429", properties:{cve_id:"CVE-2023-0429", name:"Watu Quiz WordPress plugin vulnerability", description:"The Watu Quiz WordPress plugin before 3.3.8.2 does not sanitise and escape some of its settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup).", created_at:datetime('2026-05-10T15:46:39.006Z'), published_date:"2023-02-21T08:50:57.365Z"}}, {id:"CVE-2023-0439", properties:{cve_id:"CVE-2023-0439", name:"Stored Cross-Site Scripting in NEX-Forms WordPress Plugin", description:"The NEX-Forms WordPress plugin before 8.4.4 does not escape its form name, which could lead to Stored Cross-Site Scripting issues.", created_at:datetime('2026-05-10T15:52:08.524Z'), updated_date:"2024-10-30T14:02:35.287Z", published_date:"2023-07-17T13:29:58.934Z"}}, {id:"cve-2023-0444", properties:{cve_id:"CVE-2023-0444", name:"Privilege Escalation in Delta Electronics InfraSuite Device Master", description:"A privilege escalation vulnerability exists in Delta Electronics InfraSuite Device Master 00.00.02a. A default user 'User', which is in the 'Read Only User' group, can view the password of another default user 'Administrator', which is in the 'Administrator' group. This allows any lower privileged user to log in as an administrator.", created_at:datetime('2026-05-10T15:55:15.264Z'), published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0442", properties:{cvss_score:8.5, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0442", name:"Cross-Site Scripting (XSS) in Loan Comparison WordPress plugin", created_at:datetime('2026-05-10T15:55:46.746Z'), description:"The Loan Comparison WordPress plugin before 1.5.3 does not validate and escape some of its query parameters before outputting them back in a page/post via an embedded shortcode, which could allow an attacker to inject javascript into into the site via a crafted URL.", published_date:"2023-02-21T08:51:06.188Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0443", properties:{cve_id:"2023-0443", name:"AnyWhere Elementor WordPress plugin vulnerability", description:"The AnyWhere Elementor WordPress plugin before 1.2.8 discloses a Freemius Secret Key which could be used by an attacker to purchase the pro subscription using test credit card numbers without actually paying the amount.", created_at:datetime('2026-05-10T15:56:54.509Z'), published_date:"2023-05-30T07:49:18.666Z"}}, {id:"cve-2023-0441", properties:{cve_id:"CVE-2023-0441", name:"Gallery Blocks with Lightbox WordPress plugin vulnerability", description:"The Gallery Blocks with Lightbox WordPress plugin before 3.0.8 has an AJAX endpoint that can be accessed by any authenticated users, such as subscriber.", created_at:datetime('2026-05-10T15:58:06.475Z'), published_date:"2023-03-27T15:37:16.230Z"}}, {id:"cve-2023-0448", properties:{cve_id:"CVE-2023-0448", name:"WP Helper Lite WordPress Plugin Vulnerability", description:"The WP Helper Lite WordPress plugin, in versions < 4.3, returns all GET parameters unsanitized in the response, resulting in a reflected cross-site scripting vulnerability.", created_at:datetime('2026-05-10T16:03:52.053Z'), published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0463", properties:{cve_id:"CVE-2023-0463", name:"Force offline MFA prompt setting not respected in Devolutions Remote Desktop Manager", description:"The force offline MFA prompt setting is not respected when switching to offline mode in Devolutions Remote Desktop Manager 2022.3.29 to 2022.3.30 allows a user to save sensitive data on disk.", created_at:datetime('2026-05-10T16:18:43.205Z'), published_date:"2023-01-24T16:42:58.172Z"}}, {id:"CVE-2023-0464", properties:{cve_id:"CVE-2023-0464", name:"X.509 Certificate Chain Verification Vulnerability", description:"A security vulnerability has been identified in all supported versions of OpenSSL related to the verification of X.509 certificate chains that include policy constraints.", created_at:datetime('2026-05-10T16:20:46.001Z'), published_date:"2023-03-22T16:36:47.383Z"}}, {id:"CVE-2023-0467", properties:{cve_id:"CVE-2023-0467", name:"WP Dark Mode Local File Inclusion", created_at:datetime('2026-05-10T16:21:57.19Z'), description:"The WP Dark Mode WordPress plugin before 4.0.8 does not properly sanitize the style parameter in shortcodes before using it to load a PHP template. This leads to Local File Inclusion on servers where non-existent directories may be traversed, or when chained with another vulnerability allowing arbitrary directory creation.", published_date:"2023-03-27T15:37:26.271Z"}}, {id:"CVE-2023-0465", properties:{cvss_severity:"CRITICAL", cvss_score:6.8, cve_id:"CVE-2023-0465", name:"Certificate Verification Vulnerability", created_at:datetime('2026-05-10T16:24:30.617Z'), description:"Applications that use a non-default option when verifying certificates may be vulnerable to an attack from a malicious CA to circumvent certain checks.", published_date:"2023-03-28T14:30:39.707Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0468", properties:{cve_id:"CVE-2023-0468", name:"Use-after-free flaw in io_uring/poll.c", description:"A use-after-free flaw was found in io_uring/poll.c in the io_uring subcomponent in the Linux Kernel due to a race condition of poll_refs. This flaw may cause a NULL pointer dereference.", created_at:datetime('2026-05-10T16:25:02.968Z'), published_date:"2023-01-25T00:00:00.000Z"}}, {id:"cve-2023-0471", properties:{cvss_severity:"High", cve_id:"CVE-2023-0471", name:"Use after free in WebTransport in Google Chrome prior to 109.0.5414.119", created_at:datetime('2026-05-10T16:26:13.502Z'), description:"Use after free in WebTransport in Google Chrome prior to 109.0.5414.119 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0473", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0473", name:"Type Confusion in ServiceWorker API in Google Chrome prior to 109.0.5414.119", created_at:datetime('2026-05-10T16:27:46.618Z'), description:"Type Confusion in ServiceWorker API in Google Chrome prior to 109.0.5414.119 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0474", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0474", name:"Use after free in GuestView in Google Chrome prior to 109.0.5414.119", created_at:datetime('2026-05-10T16:28:18.471Z'), description:"Use after free in GuestView in Google Chrome prior to 109.0.5414.119 allowed an attacker who convinced a user to install a malicious extension to potentially exploit heap corruption via a Chrome web app.", published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0472", properties:{cvss_severity:"High", cve_id:"CVE-2023-0472", name:"Use after free in WebRTC in Google Chrome prior to 109.0.5414.119", created_at:datetime('2026-05-10T16:28:47.578Z'), description:"Use after free in WebRTC in Google Chrome prior to 109.0.5414.119 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-01-24T00:00:00.000Z"}}, {id:"cve-2023-0476", properties:{cve_id:"CVE-2023-0476", name:"LDAP Injection in Tenable.sc", created_at:datetime('2026-05-10T16:29:16.137Z'), description:"A LDAP injection vulnerability exists in Tenable.sc due to improper validation of user-supplied input before returning it to users. An authenticated attacker could generate data in Active Directory using the application account through blind LDAP injection.", published_date:"2023-01-25T00:00:00.000Z"}}, {id:"cve-2023-0479", properties:{cve_id:"CVE-2023-0479", name:"Reflected XSS in Print Invoice & Delivery Notes for WooCommerce WordPress plugin", description:"The Print Invoice & Delivery Notes for WooCommerce WordPress plugin before 4.7.2 is vulnerable to reflected XSS by echoing a GET value in an admin note within the WooCommerce orders page.", created_at:datetime('2026-05-10T16:29:48.958Z'), published_date:"2024-01-16T15:55:08.499Z"}}, {id:"CVE-2023-0477", properties:{cve_id:"CVE-2023-0477", name:"Auto Featured Image (Auto Post Thumbnail) WordPress plugin vulnerability", description:"The Auto Featured Image (Auto Post Thumbnail) WordPress plugin before 3.9.16 includes an AJAX endpoint that allows any user with at least Author privileges to upload arbitrary files, such as PHP files.", created_at:datetime('2026-05-10T16:30:20.654Z'), updated_date:"2025-02-27T20:19:02.028Z", published_date:"2023-03-13T16:03:28.116Z"}}, {id:"CVE-2023-0484", properties:{cve_id:"CVE-2023-0484", name:"Contact Form 7 Widget For Elementor Page Builder & Gutenberg Blocks WordPress plugin vulnerability", description:"The Contact Form 7 Widget For Elementor Page Builder & Gutenberg Blocks WordPress plugin before 1.1.6 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:32:48.365Z'), published_date:"2023-03-27T15:37:28.083Z"}}, {id:"cve-2023-0483", properties:{cve_id:"CVE-2023-0483", name:"GitLab Datadog Integration API Key Extraction", description:"An issue has been discovered in GitLab affecting all versions starting from 12.1 before 15.7.8, all versions starting from 15.8 before 15.8.4, all versions starting from 15.9 before 15.9.2. It was possible for a project maintainer to extract a Datadog integration API key by modifying the site.", created_at:datetime('2026-05-10T16:34:31.466Z'), updated_date:"2025-02-28T21:31:41.989Z", published_date:"2023-03-09T00:00:00.000Z"}}, {id:"cve-2023-0480", properties:{cve_id:"CVE-2023-0480", name:"VitalPBX version 3.2.3-8 CSRF vulnerability", description:"VitalPBX version 3.2.3-8 allows an unauthenticated external attacker to obtain the instance administrator's account. This is possible because the application is vulnerable to CSRF.", created_at:datetime('2026-05-10T16:35:00.779Z'), published_date:"2023-04-04T00:00:00.000Z"}}, {id:"cve-2023-0486", properties:{cve_id:"CVE-2023-0486", name:"VitalPBX version 3.2.3-8 XSS vulnerability", description:"VitalPBX version 3.2.3-8 allows an unauthenticated external attacker to obtain the instance's administrator account via a malicious link.", created_at:datetime('2026-05-10T16:35:29.077Z'), published_date:"2023-04-04T00:00:00.000Z"}}, {id:"cve-2023-0487", properties:{cve_id:"CVE-2023-0487", name:"SQL Injection in My Sticky Elements WordPress Plugin", description:"The My Sticky Elements WordPress plugin before 2.0.9 does not properly sanitise and escape a parameter before using it in a SQL statement when deleting messages, leading to a SQL injection exploitable by high privilege users such as admin", created_at:datetime('2026-05-10T16:38:39.018Z'), published_date:"2023-02-27T15:24:39.913Z"}}, {id:"cve-2023-0489", properties:{cve_id:"CVE-2023-0489", name:"SlideOnline WordPress Plugin Vulnerability", description:"The SlideOnline WordPress plugin through 1.2.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T16:39:08.374Z'), updated_date:"2024-12-11T21:19:55.627Z", published_date:"2023-06-19T10:52:49.912Z"}}, {id:"cve-2023-0491", properties:{cve_id:"CVE-2023-0491", name:"Schedulicity WordPress Plugin Shortcode Vulnerability", description:"The Schedulicity WordPress plugin through 2.21 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T16:39:37.396Z'), updated_date:"2025-02-19T19:35:13.181Z", published_date:"2023-03-27T15:37:32.778Z"}}, {id:"CVE-2023-0495", properties:{cve_id:"CVE-2023-0495", name:"HT Slider For Elementor WordPress plugin vulnerability", description:"The HT Slider For Elementor WordPress plugin before 1.4.0 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:40:44.189Z'), published_date:"2023-03-27T15:37:24.661Z"}}, {id:"cve-2023-0492", properties:{cve_id:"2023-0492", name:"GS Products Slider for WooCommerce WordPress plugin vulnerability", description:"The GS Products Slider for WooCommerce WordPress plugin before 1.5.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T16:41:12.751Z'), published_date:"2023-02-21T08:50:47.672Z"}}, {id:"CVE-2023-0490", properties:{cve_id:"CVE-2023-0490", name:"f(x) TOC WordPress Plugin Vulnerability", description:"The f(x) TOC WordPress plugin through 1.1.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T16:43:39.576Z'), updated_date:"2025-01-14T19:35:00.208Z", published_date:"2023-05-15T12:15:39.964Z"}}, {id:"CVE-2023-0496", properties:{cve_id:"2023-0496", name:"HT Event WordPress plugin CSRF vulnerability", description:"The HT Event WordPress plugin before 1.4.6 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:44:05.628Z'), published_date:"2023-03-27T15:37:37.404Z"}}, {id:"CVE-2023-0501", properties:{cve_id:"CVE-2023-0501", name:"WP Insurance WordPress plugin CSRF vulnerability", description:"The WP Insurance WordPress plugin before 2.1.4 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:44:35.404Z'), published_date:"2023-03-27T15:37:33.856Z"}}, {id:"cve-2023-0498", properties:{cve_id:"CVE-2023-0498", name:"WP Education Plugin CSRF Vulnerability", description:"The WP Education WordPress plugin before 1.2.7 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:45:02.687Z'), published_date:"2023-03-27T15:37:18.168Z"}}, {id:"CVE-2023-0497", properties:{cve_id:"CVE-2023-0497", name:"HT Portfolio WordPress plugin vulnerability", description:"The HT Portfolio WordPress plugin before 1.1.6 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:45:33.195Z'), published_date:"2023-03-27T15:37:43.632Z"}}, {id:"cve-2023-0499", properties:{cve_id:"CVE-2023-0499", name:"Cross-Site Request Forgery (CSRF) in QuickSwish WordPress plugin", description:"The QuickSwish WordPress plugin before 1.1.0 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:46:01.009Z'), published_date:"2023-03-27T15:37:22.175Z"}}, {id:"cve-2023-0500", properties:{cve_id:"CVE-2023-0500", name:"WP Film Studio Plugin CSRF Vulnerability", description:"The WP Film Studio WordPress plugin before 1.3.5 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:46:33.043Z'), published_date:"2023-03-27T15:37:31.919Z"}}, {id:"cve-2023-0503", properties:{cve_id:"CVE-2023-0503", name:"Free WooCommerce Theme 99fy Extension WordPress plugin vulnerability", description:"The Free WooCommerce Theme 99fy Extension WordPress plugin before 1.2.8 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:47:01.162Z'), published_date:"2023-03-27T15:37:31.086Z"}}, {id:"cve-2023-0505", properties:{cve_id:"CVE-2023-0505", name:"Ever Compare WordPress plugin CSRF vulnerability", description:"The Ever Compare WordPress plugin through 1.2.3 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:49:09.285Z'), published_date:"2023-03-27T15:37:23.872Z"}}, {id:"cve-2023-0504", properties:{cve_id:"CVE-2023-0504", name:"HT Politic WordPress plugin CSRF vulnerability", description:"The HT Politic WordPress plugin before 2.3.8 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", created_at:datetime('2026-05-10T16:49:37.664Z'), published_date:"2023-03-27T15:37:15.425Z"}}, {id:"cve-2023-0502", properties:{cve_id:"CVE-2023-0502", name:"WP News Plugin CSRF Vulnerability", created_at:datetime('2026-05-10T16:50:05.096Z'), description:"The WP News WordPress plugin through 1.1.9 does not have CSRF check when activating plugins, which could allow attackers to make logged in admins activate arbitrary plugins present on the blog via a CSRF attack", published_date:"2023-03-27T15:37:29.087Z"}}, {id:"cve-2023-0514", properties:{cve_id:"CVE-2023-0514", name:"Membership Database WordPress plugin vulnerability", description:"The Membership Database WordPress plugin through 1.0 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high privilege users such as admin", created_at:datetime('2026-05-10T16:57:04.627Z'), published_date:"2023-05-08T13:58:10.717Z"}}, {id:"CVE-2023-0522", properties:{cve_id:"cve-2023-0522", name:"Enable/Disable Auto Login when Register WordPress plugin vulnerability", description:"The Enable/Disable Auto Login when Register WordPress plugin through 1.1.0 does not have CSRF check in place when updating its settings, which could allow attackers to make a logged in admin change them via a CSRF attack", created_at:datetime('2026-05-10T16:58:35.464Z'), published_date:"2023-05-08T13:58:07.769Z"}}, {id:"cve-2023-0520", properties:{cve_id:"CVE-2023-0520", name:"Stored Cross-Site Scripting in RapidExpCart WordPress Plugin", description:"The RapidExpCart WordPress plugin through 1.0 does not sanitize and escape the url parameter in the rapidexpcart endpoint before storing it and outputting it back in the page, leading to a Stored Cross-Site Scripting vulnerability which could be used against high-privilege users such as admin, furthermore lack of csrf protection means an attacker can trick a logged in admin to perform the attack by submitting a hidden form.", created_at:datetime('2026-05-10T17:05:42.986Z'), published_date:"2023-05-15T12:15:38.396Z"}}, {id:"cve-2023-0524", properties:{cve_id:"CVE-2023-0524", name:"Potential Privilege Escalation in Tenable Plugin", description:"Potential privilege escalation issue in Tenable plugin", created_at:datetime('2026-05-10T17:06:53.122Z'), published_date:"2023-02-01T00:00:00.000Z"}}, {id:"CVE-2023-0526", properties:{cve_id:"CVE-2023-0526", name:"Post Shortcode WordPress plugin vulnerability", description:"The Post Shortcode WordPress plugin through 2.0.9 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T17:11:16.264Z'), updated_date:"2025-01-29T14:57:59.876Z", published_date:"2023-05-08T13:58:24.790Z"}}, {id:"CVE-2023-0535", properties:{cve_id:"CVE-2023-0535", name:"Stored Cross-Site Scripting (XSS) in Donation Block For PayPal WordPress plugin", description:"The Donation Block For PayPal WordPress plugin before 2.1.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:20:54.173Z'), published_date:"2023-02-27T15:24:38.235Z"}}, {id:"CVE-2023-0539", properties:{cve_id:"CVE-2023-0539", name:"GS Insever Portfolio WordPress plugin vulnerability", description:"The GS Insever Portfolio WordPress plugin before 1.4.5 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:21:25.176Z'), updated_date:"2025-03-11T02:53:55.915Z", published_date:"2023-02-27T15:24:35.760Z"}}, {id:"CVE-2023-0536", properties:{cve_id:"CVE-2023-0536", name:"Wp-D3 WordPress plugin vulnerability", description:"The Wp-D3 WordPress plugin through 2.4.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:21:54.965Z'), updated_date:"2025-05-05T16:08:38.864Z", published_date:"2023-05-08T13:58:16.532Z"}}, {id:"CVE-2023-0538", properties:{cve_id:"CVE-2023-0538", name:"Campaign URL Builder WordPress plugin vulnerability", description:"The Campaign URL Builder WordPress plugin before 1.8.2 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T17:22:30.826Z'), updated_date:"2025-02-27T15:52:38.361Z", published_date:"2023-03-13T16:03:33.950Z"}}, {id:"CVE-2023-0537", properties:{cve_id:"CVE-2023-0537", name:"Stored Cross-Site Scripting (XSS) in Product Slider For WooCommerce Lite", description:"The Product Slider For WooCommerce Lite WordPress plugin through 1.1.7 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T17:23:00.444Z'), published_date:"2023-05-08T13:58:22.926Z"}}, {id:"cve-2023-0540", properties:{cve_id:"2023-0540", name:"GS Filterable Portfolio WordPress plugin vulnerability", description:"The GS Filterable Portfolio WordPress plugin before 1.6.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:23:29.96Z'), published_date:"2023-02-21T08:50:58.166Z"}}, {id:"CVE-2023-0542", properties:{cve_id:"CVE-2023-0542", name:"Custom Post Type List Shortcode WordPress plugin vulnerability", description:"The Custom Post Type List Shortcode WordPress plugin through 1.4.4 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:24:00.891Z'), published_date:"2023-05-08T13:58:11.670Z"}}, {id:"cve-2023-0543", properties:{cve_id:"CVE-2023-0543", name:"Arigato Autoresponder and Newsletter Plugin Vulnerability", description:"The Arigato Autoresponder and Newsletter WordPress plugin before 2.1.7.2 does not sanitize and escape some of its settings, which could allow high-privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed.", created_at:datetime('2026-05-10T17:24:30.76Z'), published_date:"2023-02-27T15:24:34.100Z"}}, {id:"cve-2023-0544", properties:{cve_id:"CVE-2023-0544", name:"WP Login Box WordPress plugin vulnerability", description:"The WP Login Box WordPress plugin through 2.0.2 does not sanitise and escape some of its settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup)", created_at:datetime('2026-05-10T17:25:00.62Z'), updated_date:"2025-05-05T16:08:29.845Z", published_date:"2023-05-08T13:58:06.121Z"}}, {id:"CVE-2023-0541", properties:{cve_id:"CVE-2023-0541", name:"GS Books Showcase WordPress plugin vulnerability", description:"The GS Books Showcase WordPress plugin before 1.3.1 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T17:27:21.748Z'), updated_date:"2025-03-12T20:27:51.775Z", published_date:"2023-02-21T08:50:54.939Z"}}, {id:"cve-2023-0545", properties:{cve_id:"CVE-2023-0545", name:"Hostel WordPress plugin vulnerability", description:"The Hostel WordPress plugin before 1.1.5.2 does not sanitise and escape some of its settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup).", created_at:datetime('2026-05-10T17:27:51.313Z'), updated_date:"2025-01-08T17:06:22.275Z", published_date:"2023-06-05T13:38:58.659Z"}}, {id:"CVE-2023-0546", properties:{cve_id:"CVE-2023-0546", name:"Contact Form Plugin WordPress plugin vulnerability", description:"The Contact Form Plugin WordPress plugin before 4.3.25 does not properly sanitize and escape the srcdoc attribute in iframes in it's custom HTML field type, allowing a logged in user with roles as low as contributor to inject arbitrary javascript into a form which will trigger for any visitor to the form or admins previewing or editing the form.", created_at:datetime('2026-05-10T17:28:22.469Z'), updated_date:"2025-02-11T21:04:47.802Z", published_date:"2023-04-10T13:18:07.349Z"}}, {id:"CVE-2023-0552", properties:{cve_id:"2023-0552", name:"Open Redirect in Registration Forms WordPress plugin", description:"The Registration Forms WordPress plugin before 3.8.2.3 does not properly validate the redirection URL when logging in and login out, leading to an Open Redirect vulnerability", created_at:datetime('2026-05-10T17:28:51.638Z'), published_date:"2023-02-27T15:24:31.331Z"}}, {id:"CVE-2023-0548", properties:{cve_id:"CVE-2023-0548", name:"Stored Cross-Site Scripting (XSS) in Namaste! LMS WordPress plugin", description:"The Namaste! LMS WordPress plugin before 2.5.9.4 does not sanitize and escape some of its settings, which could allow high-privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup).", created_at:datetime('2026-05-10T17:29:21.512Z'), published_date:"2023-02-27T15:24:28.364Z"}}, {id:"CVE-2023-0551", properties:{cve_id:"CVE-2023-0551", name:"REST API TO MiniProgram WordPress plugin vulnerability", description:"The REST API TO MiniProgram WordPress plugin through 4.6.1 does not have authorisation and CSRF checks in an AJAX action, allowing ay authenticated users, such as subscriber to call and delete arbitrary attachments", created_at:datetime('2026-05-10T17:30:51.219Z'), published_date:"2023-08-16T11:03:30.386Z"}}, {id:"CVE-2023-0559", properties:{cve_id:"CVE-2023-0559", name:"GS Portfolio for Envato WordPress plugin vulnerability", description:"The GS Portfolio for Envato WordPress plugin before 1.4.0 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embedded, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T17:37:00.447Z'), updated_date:"2025-03-14T18:12:24.923Z", published_date:"2023-02-21T08:50:46.871Z"}}, {id:"CVE-2023-0579", properties:{cve_id:"2023-0579", name:"YARPP WordPress Plugin SQL Injection Vulnerability", description:"The YARPP WordPress plugin before 5.30.3 does not validate and escape some of its shortcode attributes before using them in SQL statement/s, which could allow any authenticated users, such as subscribers to perform SQL Injection attacks.", created_at:datetime('2026-05-10T18:04:02.183Z'), published_date:"2023-08-16T11:03:21.175Z"}}, {id:"CVE-2023-0588", properties:{cve_id:"CVE-2023-0588", name:"Reflected Cross-Site Scripting in Catalyst Connect Zoho CRM Client Portal WordPress plugin", description:"The Catalyst Connect Zoho CRM Client Portal WordPress plugin before 2.1.0 does not sanitize and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high-privilege users such as admin.", created_at:datetime('2026-05-10T18:05:17.294Z'), updated_date:"2024-11-27T17:02:36.727Z", published_date:"2023-06-27T13:17:24.246Z"}}, {id:"cve-2023-0587", properties:{cve_id:"CVE-2023-0587", name:"File Upload Vulnerability in Trend Micro Apex One Server", description:"A file upload vulnerability in exists in Trend Micro Apex One server build 11110.", created_at:datetime('2026-05-10T18:05:43.612Z'), published_date:"2023-02-01T00:00:00.000Z"}}, {id:"cve-2023-0589", properties:{cve_id:"CVE-2023-0589", name:"WP Image Carousel Cross-Site Scripting", description:"The WP Image Carousel WordPress plugin through 1.0.2 does not sanitise and escape some parameters, which could allow users with a role as low as contributor to perform Cross-Site Scripting attacks.", created_at:datetime('2026-05-10T18:06:54.689Z'), published_date:"2023-03-27T15:37:39.286Z"}}, {id:"CVE-2023-0602", properties:{cve_id:"2023-0602", name:"Twittee Text Tweet WordPress plugin vulnerability", description:"The Twittee Text Tweet WordPress plugin through 1.0.8 does not properly escape POST values which are printed back to the user inside one of the plugin's administrative page, which allows reflected XSS attacks targeting administrators to happen.", created_at:datetime('2026-05-10T18:15:53.931Z'), updated_date:"2024-08-02T05:17:50.079Z", published_date:"2023-07-31T09:37:33.393Z"}}, {id:"cve-2023-0600", properties:{cve_id:"CVE-2023-0600", name:"WP Visitor Statistics (Real Time Traffic) WordPress plugin SQL Injection vulnerability", description:"The WP Visitor Statistics (Real Time Traffic) WordPress plugin before 6.9 does not escape user input which is concatenated to an SQL query, allowing unauthenticated visitors to conduct SQL Injection attacks.", created_at:datetime('2026-05-10T18:16:21.069Z'), published_date:"2023-05-15T12:15:31.686Z"}}] AS row
CREATE (n:Vulnerability{id: row.id}) SET n += row.properties;
UNWIND [{id:"CVE-2023-0603", properties:{cve_id:"CVE-2023-0603", name:"Sloth Logo Customizer WordPress plugin vulnerability", description:"The Sloth Logo Customizer WordPress plugin through 2.0.2 does not have CSRF check when updating its settings, and is missing sanitisation as well as escaping, which could allow attackers to make logged in admin add Stored XSS payloads via a CSRF attack", created_at:datetime('2026-05-10T18:16:57.803Z'), updated_date:"2025-04-23T16:21:45.795Z", published_date:"2023-05-08T13:58:23.850Z"}}, {id:"CVE-2023-0605", properties:{cve_id:"CVE-2023-0605", name:"Auto Rename Media On Upload WordPress plugin vulnerability", description:"The Auto Rename Media On Upload WordPress plugin before 1.1.0 does not sanitise and escape some of its settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup).", created_at:datetime('2026-05-10T18:17:29.58Z'), published_date:"2023-04-10T13:17:57.330Z"}}, {id:"CVE-2023-0604", properties:{cve_id:"CVE-2023-0604", name:"WP Food Manager WordPress plugin vulnerability", description:"The WP Food Manager WordPress plugin before 1.0.4 does not sanitise and escape some of its settings, which could allow high privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup)", created_at:datetime('2026-05-10T18:19:04.121Z'), updated_date:"2024-10-10T19:42:21.367Z", published_date:"2023-08-07T14:31:24.845Z"}}, {id:"cve-2023-0616", properties:{cve_id:"CVE-2023-0616", name:"Thunderbird MIME Data Processing Vulnerability", description:"If a MIME email combines OpenPGP and OpenPGP MIME data in a certain way Thunderbird repeatedly attempts to process and display the message, which could cause Thunderbird's user interface to lock up and no longer respond to the user's actions. An attacker could send a crafted message with this structure to attempt a DoS attack.", created_at:datetime('2026-05-10T18:26:39.682Z'), published_date:"2023-06-02T00:00:00.000Z"}}, {id:"cve-2023-0621", properties:{cvss_score:9.8, cvss_severity:"CRITICAL", cve_id:"CVE-2023-0621", name:"Out-of-bounds read vulnerability in Cscape Envision RV version 4.60", created_at:datetime('2026-05-10T18:31:35.488Z'), description:"Cscape Envision RV version 4.60 is vulnerable to an out-of-bounds read vulnerability when parsing project (i.e. HMI) files. The product lacks proper validation of user-supplied data, which could result in reads past the end of allocated data structures. An attacker could leverage these vulnerabilities to execute arbitrary code in the context of the current process.", updated_date:"2025-01-17T22:09:20.608Z", published_date:"2023-03-09T21:13:06.983Z", attack_vector:"NETWORK"}}, {id:"cve-2023-0623", properties:{cve_id:"CVE-2023-0623", name:"Out-of-bounds write vulnerability in Cscape Envision RV version 4.60", description:"Cscape Envision RV version 4.60 is vulnerable to an out-of-bounds write vulnerability when parsing project (i.e. HMI) files. The product lacks proper validation of user-supplied data, which could result in writes past the end of allocated data structures. An attacker could leverage these vulnerabilities to execute arbitrary code in the context of the current process.", created_at:datetime('2026-05-10T18:34:37.151Z'), published_date:"2023-03-09T21:12:00.661Z"}}, {id:"cve-2023-0624", properties:{cve_id:"CVE-2023-0624", name:"OrangeScrum version 2.0.11 arbitrary user account access", description:"OrangeScrum version 2.0.11 allows an external attacker to obtain arbitrary user accounts from the application.", created_at:datetime('2026-05-10T18:35:51.567Z'), published_date:"2023-02-09T00:00:00.000Z"}}, {id:"cve-2023-0631", properties:{cve_id:"CVE-2023-0631", name:"Paid Memberships Pro WordPress plugin vulnerability", description:"The Paid Memberships Pro WordPress plugin before 2.9.12 does not prevent subscribers from rendering shortcodes that concatenate attributes directly into an SQL query.", created_at:datetime('2026-05-10T18:36:57.675Z'), published_date:"2023-03-20T15:52:10.755Z"}}, {id:"CVE-2023-0630", properties:{cve_id:"CVE-2023-0630", name:"SQL Injection in Slimstat Analytics WordPress Plugin", description:"The Slimstat Analytics WordPress plugin before 4.9.3.3 does not prevent subscribers from rendering shortcodes that concatenates attributes directly into an SQL query.", created_at:datetime('2026-05-10T18:41:09.424Z'), published_date:"2023-03-20T15:52:13.523Z"}}, {id:"CVE-2023-0644", properties:{cve_id:"CVE-2023-0644", name:"Push Notifications for WordPress by PushAssist plugin vulnerability", description:"The Push Notifications for WordPress by PushAssist WordPress plugin through 3.0.8 does not sanitise and escape various parameters before outputting them back in pages, leading to Reflected Cross-Site Scripting which could be used against high privilege users such as admin.", created_at:datetime('2026-05-10T18:49:47.242Z'), updated_date:"2025-01-14T18:21:36.964Z", published_date:"2023-05-15T12:15:40.717Z"}}, {id:"cve-2023-0661", properties:{cve_id:"CVE-2023-0661", name:"Improper access control in Devolutions Server", description:"Improper access control in Devolutions Server allows an authenticated user to access unauthorized sensitive data.", created_at:datetime('2026-05-10T19:09:33.944Z'), published_date:"2023-02-03T15:48:17.672Z"}}, {id:"cve-2023-0660", properties:{cve_id:"CVE-2023-0660", name:"Smart Slider 3 WordPress plugin vulnerability", description:"The Smart Slider 3 WordPress plugin before 3.5.1.14 does not properly validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-10T19:11:01.085Z'), updated_date:"2025-02-19T19:01:04.954Z", published_date:"2023-03-27T15:37:19.768Z"}}, {id:"CVE-2023-0670", properties:{cve_id:"CVE-2023-0670", name:"Ulearn version a5a7ca20de859051ea0470542844980a66dfc05d remote code execution", description:"Ulearn version a5a7ca20de859051ea0470542844980a66dfc05d allows an attacker with administrator permissions to obtain remote code execution on the server through the image upload functionality.", created_at:datetime('2026-05-10T19:12:15.693Z'), updated_date:"2025-02-13T19:35:48.795Z", published_date:"2023-04-05T00:00:00.000Z"}}, {id:"cve-2023-0696", properties:{cvss_severity:"High", cve_id:"CVE-2023-0696", name:"Type confusion in V8 in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:37:39.109Z'), description:"Type confusion in V8 in Google Chrome prior to 110.0.5481.77 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0699", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0699", name:"Use after free in GPU in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:45:01.565Z'), description:"Use after free in GPU in Google Chrome prior to 110.0.5481.77 allowed a remote attacker to potentially exploit heap corruption via a crafted HTML page and browser shutdown.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0698", properties:{cvss_severity:"HIGH", cve_id:"CVE-2023-0698", name:"Out of bounds read in WebRTC in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:45:30.241Z'), description:"Out of bounds read in WebRTC in Google Chrome prior to 110.0.5481.77 allowed a remote attacker to perform an out of bounds memory read via a crafted HTML page.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0701", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0701", name:"Heap buffer overflow in WebUI in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:45:55.338Z'), description:"Heap buffer overflow in WebUI in Google Chrome prior to 110.0.5481.77 allowed a remote attacker who convinced a user to engage in specific UI interactions to potentially exploit heap corruption via UI interaction . (Chromium security severity: Medium)", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0702", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0702", name:"Type confusion in Data Transfer in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:48:27.798Z'), description:"Type confusion in Data Transfer in Google Chrome prior to 110.0.5481.77 allowed a remote attacker who convinced a user to engage in specific UI interactions to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0703", properties:{cvss_severity:"MEDIUM", cve_id:"CVE-2023-0703", name:"Type confusion in DevTools in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:49:37.963Z'), description:"Type confusion in DevTools in Google Chrome prior to 110.0.5481.77 allowed a remote attacker who convinced a user to engage in specific UI interactions to potentially exploit heap corruption via UI interactions.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0705", properties:{cvss_severity:"LOW", cve_id:"CVE-2023-0705", name:"Integer overflow in Core in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:50:17.382Z'), description:"Integer overflow in Core in Google Chrome prior to 110.0.5481.77 allowed a remote attacker who had one a race condition to potentially exploit heap corruption via a crafted HTML page.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"cve-2023-0704", properties:{cvss_severity:"Low", cve_id:"CVE-2023-0704", name:"Insufficient policy enforcement in DevTools in Google Chrome prior to 110.0.5481.77", created_at:datetime('2026-05-10T19:53:00.021Z'), description:"Insufficient policy enforcement in DevTools in Google Chrome prior to 110.0.5481.77 allowed a remote attacker to bypass same origin policy and proxy settings via a crafted HTML page.", published_date:"2023-02-07T00:00:00.000Z"}}, {id:"CVE-2023-0733", properties:{cve_id:"CVE-2023-0733", name:"Newsletter Popup WordPress plugin vulnerability", description:"The Newsletter Popup WordPress plugin through 1.2 does not sanitise and escape some of its settings, which could allow unauthenticated users to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-11T12:45:45.628Z'), updated_date:"2025-01-10T21:07:32.716Z", published_date:"2023-05-30T07:49:10.677Z"}}, {id:"cve-2023-0738", properties:{cve_id:"CVE-2023-0738", name:"OrangeScrum version 2.0.11 arbitrary user account access", description:"OrangeScrum version 2.0.11 allows an external attacker to obtain arbitrary user accounts from the application.", created_at:datetime('2026-05-11T12:49:16.958Z'), published_date:"2023-04-04T00:00:00.000Z", status:"published"}}, {id:"cve-2023-0749", properties:{cve_id:"CVE-2023-0749", name:"Ocean Extra WordPress plugin vulnerability", description:"The Ocean Extra WordPress plugin before 2.1.3 does not ensure that the template to be loaded via a shortcode is actually a template, allowing any authenticated users such as subscriber to retrieve the content of arbitrary posts, such as draft, private or even password protected ones.", created_at:datetime('2026-05-11T13:03:03.845Z'), published_date:"2023-03-13T16:03:31.466Z"}}, {id:"cve-2023-0756", properties:{cve_id:"CVE-2023-0756", name:"GitLab Repository Malicious Code Execution", description:"An issue has been discovered in GitLab affecting all versions before 15.9.6, all versions starting from 15.10 before 15.10.5, all versions starting from 15.11 before 15.11.1. The main branch of a repository with a specially crafted name allows an attacker to create repositories with malicious code, victims who clone or download these repositories will execute arbitrary code on their systems.", created_at:datetime('2026-05-11T13:09:34.971Z'), updated_date:"2025-02-12T16:08:12.043Z", published_date:"2023-05-03T00:00:00.000Z"}}, {id:"CVE-2023-0761", properties:{cve_id:"CVE-2023-0761", name:"Clock In Portal- Staff & Attendance Management WordPress plugin vulnerability", description:"The Clock In Portal- Staff & Attendance Management WordPress plugin through 2.1 does not have CSRF check when deleting Staff members, which could allow attackers to make logged in admins delete arbitrary Staff via a CSRF attack", created_at:datetime('2026-05-11T13:17:25.861Z'), published_date:"2023-05-15T12:15:43.882Z"}}, {id:"cve-2023-0763", properties:{cve_id:"CVE-2023-0763", name:"Clock In Portal- Staff & Attendance Management WordPress plugin vulnerability", description:"The Clock In Portal- Staff & Attendance Management WordPress plugin through 2.1 does not have CSRF check when deleting Holidays, which could allow attackers to make logged in admins delete arbitrary holidays via a CSRF attack", created_at:datetime('2026-05-11T13:17:55.895Z'), published_date:"2023-05-15T12:15:37.541Z"}}, {id:"cve-2023-0762", properties:{cve_id:"CVE-2023-0762", name:"Clock In Portal- Staff & Attendance Management WordPress plugin vulnerability", description:"The Clock In Portal- Staff & Attendance Management WordPress plugin through 2.1 does not have CSRF check when deleting designations, which could allow attackers to make logged in admins delete arbitrary designations via a CSRF attack", created_at:datetime('2026-05-11T13:18:25.161Z'), published_date:"2023-05-15T12:15:32.523Z"}}, {id:"CVE-2023-0764", properties:{cve_id:"CVE-2023-0764", name:"Gallery by BestWebSoft WordPress plugin Stored Cross-Site Scription vulnerability", description:"The Gallery by BestWebSoft WordPress plugin before 4.7.0 does not perform proper sanitization of gallery information, leading to a Stored Cross-Site Scription vulnerability.", created_at:datetime('2026-05-11T13:19:01.133Z'), updated_date:"2025-02-06T16:43:09.033Z", published_date:"2023-04-17T12:17:37.533Z"}}, {id:"CVE-2023-0766", properties:{cve_id:"2023-0766", name:"Newsletter Popup WordPress plugin vulnerability", description:"The Newsletter Popup WordPress plugin through 1.2 does not have CSRF checks in some places, which could allow attackers to make logged in users perform unwanted actions via CSRF attacks as the wp_newsletter_show_localrecord page is not protected with a nonce.", created_at:datetime('2026-05-11T13:19:28.553Z'), published_date:"2023-05-30T07:49:19.438Z"}}, {id:"cve-2023-0765", properties:{cve_id:"CVE-2023-0765", name:"Blind SQL Injection in Gallery by BestWebSoft WordPress plugin", description:"The Gallery by BestWebSoft WordPress plugin before 4.7.0 does not properly escape values used in SQL queries, leading to an Blind SQL Injection vulnerability.", created_at:datetime('2026-05-11T13:20:21.096Z'), published_date:"2023-04-17T12:17:39.159Z"}}, {id:"cve-2023-0769", properties:{cve_id:"CVE-2023-0769", name:"hiWeb Migration Simple WordPress plugin vulnerability", description:"The hiWeb Migration Simple WordPress plugin through 2.0.0.1 does not sanitise and escape a parameter before outputting it back in the page, leading to a Reflected Cross-Site Scripting which could be used against high-privilege users such as admins.", created_at:datetime('2026-05-11T13:21:41.321Z'), updated_date:"2025-06-02T15:09:44.119Z", published_date:"2024-01-16T15:56:25.178Z"}}, {id:"cve-2023-0767", properties:{cve_id:"CVE-2023-0767", name:"Arbitrary Memory Write via PKCS 12 Safe Bag Attributes", description:"An attacker could construct a PKCS 12 cert bundle in such a way that could allow for arbitrary memory writes via PKCS 12 Safe Bag attributes being mishandled.", created_at:datetime('2026-05-11T13:22:29.288Z'), published_date:"2023-06-02T00:00:00.000Z"}}, {id:"cve-2023-0768", properties:{cve_id:"CVE-2023-0768", name:"SQL Injection in Avirato hotels online booking engine WordPress plugin", description:"The Avirato hotels online booking engine WordPress plugin through 5.0.5 does not validate and escape some of its shortcode attributes before using them in SQL statement/s, which could allow any authenticated users, such as subscriber to perform SQL Injection attacks.", created_at:datetime('2026-05-11T13:23:40.147Z'), published_date:"2023-05-08T13:58:02.011Z"}}, {id:"CVE-2023-0772", properties:{cve_id:"CVE-2023-0772", name:"Popup Builder by OptinMonster WordPress plugin vulnerability", description:"The Popup Builder by OptinMonster WordPress plugin before 2.12.2 does not ensure that the campaign to be loaded via some shortcodes is actually a campaign, allowing any authenticated users such as subscriber to retrieve the content of arbitrary posts, like draft, private or even password protected ones.", created_at:datetime('2026-05-11T13:24:50.239Z'), updated_date:"2025-02-27T21:10:26.369Z", published_date:"2023-03-13T16:03:30.688Z"}}, {id:"CVE-2023-0795", properties:{cve_id:"CVE-2023-0795", name:"LibTIFF tiffcrop out-of-bounds read", created_at:datetime('2026-05-11T13:39:13.704Z'), description:"LibTIFF 4.4.0 has an out-of-bounds read in tiffcrop in tools/tiffcrop.c:3488, allowing attackers to cause a denial-of-service via a crafted tiff file.", updated_date:"2025-03-21T19:12:39.089Z", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0796", properties:{cve_id:"CVE-2023-0796", name:"LibTIFF tiffcrop out-of-bounds read", created_at:datetime('2026-05-11T13:42:14.314Z'), description:"LibTIFF 4.4.0 has an out-of-bounds read in tiffcrop in tools/tiffcrop.c:3592, allowing attackers to cause a denial-of-service via a crafted tiff file.", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0797", properties:{cve_id:"CVE-2023-0797", name:"LibTIFF tiffcrop out-of-bounds read", created_at:datetime('2026-05-11T13:42:40.254Z'), description:"LibTIFF 4.4.0 has an out-of-bounds read in tiffcrop in libtiff/tif_unix.c:368, invoked by tools/tiffcrop.c:2903 and tools/tiffcrop.c:6921, allowing attackers to cause a denial-of-service via a crafted tiff file.", updated_date:"2025-03-21T19:03:22.116Z", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0798", properties:{cve_id:"CVE-2023-0798", name:"LibTIFF tiffcrop out-of-bounds read", created_at:datetime('2026-05-11T13:43:27.556Z'), description:"LibTIFF 4.4.0 has an out-of-bounds read in tiffcrop in tools/tiffcrop.c:3400, allowing attackers to cause a denial-of-service via a crafted tiff file.", updated_date:"2025-03-21T19:02:57.304Z", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0799", properties:{cve_id:"CVE-2023-0799", name:"LibTIFF tiffcrop out-of-bounds read", created_at:datetime('2026-05-11T13:44:04.931Z'), description:"LibTIFF 4.4.0 has an out-of-bounds read in tiffcrop in tools/tiffcrop.c:3701, allowing attackers to cause a denial-of-service via a crafted tiff file.", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0800", properties:{cve_id:"CVE-2023-0800", name:"LibTIFF tiffcrop out-of-bounds write vulnerability", description:"LibTIFF 4.4.0 has an out-of-bounds write in tiffcrop in tools/tiffcrop.c:3502, allowing attackers to cause a denial-of-service via a crafted tiff file.", created_at:datetime('2026-05-11T13:44:47.784Z'), published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0801", properties:{cve_id:"CVE-2023-0801", name:"LibTIFF tiffcrop out-of-bounds write vulnerability", description:"LibTIFF 4.4.0 has an out-of-bounds write in tiffcrop in libtiff/tif_unix.c:368, invoked by tools/tiffcrop.c:2903 and tools/tiffcrop.c:6778, allowing attackers to cause a denial-of-service via a crafted tiff file.", created_at:datetime('2026-05-11T13:45:53.944Z'), updated_date:"2025-03-21T19:00:43.776Z", published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0802", properties:{cve_id:"CVE-2023-0802", name:"LibTIFF tiffcrop out-of-bounds write vulnerability", description:"LibTIFF 4.4.0 has an out-of-bounds write in tiffcrop in tools/tiffcrop.c:3724, allowing attackers to cause a denial-of-service via a crafted tiff file.", created_at:datetime('2026-05-11T13:46:32.048Z'), published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0803", properties:{cve_id:"CVE-2023-0803", name:"LibTIFF tiffcrop out-of-bounds write vulnerability", description:"LibTIFF 4.4.0 has an out-of-bounds write in tiffcrop in tools/tiffcrop.c:3516, allowing attackers to cause a denial-of-service via a crafted tiff file.", created_at:datetime('2026-05-11T13:47:10.739Z'), published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0804", properties:{cve_id:"CVE-2023-0804", name:"LibTIFF tiffcrop out-of-bounds write vulnerability", description:"LibTIFF 4.4.0 has an out-of-bounds write in tiffcrop in tools/tiffcrop.c:3609, allowing attackers to cause a denial-of-service via a crafted tiff file.", created_at:datetime('2026-05-11T13:47:45.441Z'), published_date:"2023-02-13T00:00:00.000Z"}}, {id:"cve-2023-0805", properties:{cve_id:"CVE-2023-0805", name:"GitLab EE Public Group Access Issue", created_at:datetime('2026-05-11T13:50:31.157Z'), description:"A malicious group member may continue to have access to the public projects of a public group even after being banned from the public group by the owner.", published_date:"2023-05-03T00:00:00.000Z"}}, {id:"cve-2023-0812", properties:{cve_id:"CVE-2023-0812", name:"Unauthenticated Data Disclosure in Active Directory Integration / LDAP Integration WordPress Plugin", description:"The Active Directory Integration / LDAP Integration WordPress plugin before 4.1.1 does not have proper authorization or nonce values for some POST requests, leading to unauthenticated data disclosure.", created_at:datetime('2026-05-11T13:56:36.065Z'), published_date:"2023-05-15T12:15:39.193Z"}}, {id:"cve-2023-0816", properties:{cve_id:"CVE-2023-0816", name:"Formidable Forms WordPress plugin IP Address Spoofing", description:"The Formidable Forms WordPress plugin before 6.1 uses several potentially untrusted headers to determine the IP address of the client, leading to IP Address spoofing and bypass of anti-spam protections.", created_at:datetime('2026-05-11T13:59:46.054Z'), published_date:"2023-03-27T15:37:17.374Z"}}, {id:"cve-2023-0820", properties:{cve_id:"2023-0820", name:"User Role by BestWebSoft WordPress plugin CSRF vulnerability", description:"The User Role by BestWebSoft WordPress plugin before 1.6.7 does not protect against CSRF in requests to update role capabilities, leading to arbitrary privilege escalation of any role.", created_at:datetime('2026-05-11T14:03:32.803Z'), published_date:"2023-04-03T14:38:25.817Z"}}, {id:"CVE-2023-0823", properties:{cve_id:"CVE-2023-0823", name:"Cookie Notice & Compliance for GDPR / CCPA WordPress plugin vulnerability", description:"The Cookie Notice & Compliance for GDPR / CCPA WordPress plugin before 2.4.7 does not validate and escape some of its shortcode attributes before outputting them back in a page/post where the shortcode is embed, which could allow users with the contributor role and above to perform Stored Cross-Site Scripting attacks", created_at:datetime('2026-05-11T14:04:38.891Z'), updated_date:"2025-02-19T16:50:20.556Z", published_date:"2023-03-27T15:37:40.612Z"}}, {id:"cve-2023-0824", properties:{cve_id:"2023-0824", name:"User registration & user profile WordPress plugin vulnerability", description:"The User registration & user profile WordPress plugin through 2.0 does not have CSRF check in some places, and is missing sanitisation as well as escaping, which could allow attackers to make logged-in admin add Stored XSS payloads via a CSRF attack.", created_at:datetime('2026-05-11T14:06:23.532Z'), published_date:"2024-01-16T15:56:28.126Z"}}, {id:"cve-2023-0835", properties:{cve_id:"CVE-2023-0835", name:"markdown-pdf version 11.0.0 arbitrary local file access", description:"markdown-pdf version 11.0.0 allows an external attacker to remotely obtain arbitrary local files.", created_at:datetime('2026-05-11T14:12:12.789Z'), published_date:"2023-04-04T00:00:00.000Z", status:"published"}}, {id:"cve-2023-0838", properties:{cve_id:"CVE-2023-0838", name:"GitLab Webhook Secret Leaks", created_at:datetime('2026-05-11T14:18:48.008Z'), description:"An issue has been discovered in GitLab affecting versions starting from 15.1 before 15.8.5, 15.9 before 15.9.4, and 15.10 before 15.10.1. A maintainer could modify a webhook URL to leak masked webhook secrets by adding a new parameter to the url. This addresses an incomplete fix for CVE-2022-4342.", updated_date:"2025-02-10T20:59:42.972Z", published_date:"2023-04-05T00:00:00.000Z"}}, {id:"cve-2023-0844", properties:{cve_id:"CVE-2023-0844", name:"Stored Cross-Site Scripting in Namaste! LMS WordPress plugin", description:"The Namaste! LMS WordPress plugin before 2.6 does not sanitize and escape some of its settings, which could allow high-privilege users such as admin to perform Stored Cross-Site Scripting attacks even when the unfiltered_html capability is disallowed (for example in multisite setup).", created_at:datetime('2026-05-11T14:23:41.648Z'), published_date:"2023-03-13T16:03:35.583Z"}}, {id:"cve-2023-0842", properties:{cve_id:"CVE-2023-0842", name:"xml2js version 0.4.23 XML Key Injection", description:"xml2js version 0.4.23 allows an external attacker to edit or add new properties to an object.", created_at:datetime('2026-05-11T14:25:45.86Z'), published_date:"2023-04-05T00:00:00.000Z"}}, {id:"CVE-2023-0865", properties:{cve_id:"CVE-2023-0865", name:"WooCommerce Multiple Customer Addresses & Shipping Plugin Vulnerability", description:"The WooCommerce Multiple Customer Addresses & Shipping WordPress plugin before 21.7 does not ensure that the address to add/update/retrieve/delete and duplicate belong to the user making the request, or is from a high privilege users, allowing any authenticated users, such as subscriber to add/update/duplicate/delete as well as retrieve addresses of other users.", created_at:datetime('2026-05-11T14:43:39.233Z'), updated_date:"2025-02-26T14:33:12.565Z", published_date:"2023-03-20T15:52:15.223Z"}}] AS row
CREATE (n:Vulnerability{id: row.id}) SET n += row.properties;
