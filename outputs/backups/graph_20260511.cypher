e/Small Office Multifunction Printers and Laser Printers", created_at:datetime('2026-05-11T14:35:21.078Z'), id:"platform-canon"}}, {_id:4281, properties:{technology_type:"Multifunction Printer", platform_name:"Satera LBP660C Series/LBP620C Series/MF740C Series/MF640C Series", name:"Satera LBP660C Series/LBP620C Series/MF740C Series/MF640C Series firmware Ver.11.04 and earlier sold in Japan", created_at:datetime('2026-05-11T14:38:25.232Z'), id:"canon-office-printer-japan"}}, {_id:4282, properties:{technology_type:"Multifunction Printer", platform_name:"Color imageCLASS LBP660C Series/LBP 620C Series/X LBP1127C/MF740C Series/MF640C Series/X MF1127C", name:"Color imageCLASS LBP660C Series/LBP 620C Series/X LBP1127C/MF740C Series/MF640C Series/X MF1127C firmware Ver.11.04 and earlier sold in US", created_at:datetime('2026-05-11T14:38:25.234Z'), id:"canon-office-printer-us"}}, {_id:4283, properties:{technology_type:"Multifunction Printer", platform_name:"i-SENSYS LBP660C Series/LBP620C Series/MF740C Series/MF640C Series, C1127P, C1127iF, C1127i", name:"i-SENSYS LBP660C Series/LBP620C Series/MF740C Series/MF640C Series, C1127P, C1127iF, C1127i firmware Ver.11.04 and earlier sold in Europe", created_at:datetime('2026-05-11T14:38:25.238Z'), id:"canon-office-printer-europe"}}, {_id:4286, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (UL40/80A)", name:"ABB - Terra AC wallbox (UL40/80A)", created_at:datetime('2026-05-11T14:45:13.834Z'), id:"abb-terra-ac-wallbox-ul40-80a"}}, {_id:4287, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (UL32A)", name:"ABB - Terra AC wallbox (UL32A)", created_at:datetime('2026-05-11T14:45:13.837Z'), id:"abb-terra-ac-wallbox-ul32a"}}, {_id:4288, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (CE) (Terra AC MID)", name:"ABB - Terra AC wallbox (CE) (Terra AC MID)", created_at:datetime('2026-05-11T14:45:13.839Z'), id:"abb-terra-ac-wallbox-ce-terra-ac-mid"}}, {_id:4289, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (CE) Terra AC Juno CE", name:"ABB - Terra AC wallbox (CE) Terra AC Juno CE", created_at:datetime('2026-05-11T14:45:13.842Z'), id:"abb-terra-ac-wallbox-ce-terra-ac-juno-ce"}}, {_id:4290, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (CE) Terra AC PTB", name:"ABB - Terra AC wallbox (CE) Terra AC PTB", created_at:datetime('2026-05-11T14:45:13.845Z'), id:"abb-terra-ac-wallbox-ce-terra-ac-ptb"}}, {_id:4291, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (CE) Symbiosis", name:"ABB - Terra AC wallbox (CE) Symbiosis", created_at:datetime('2026-05-11T14:45:13.85Z'), id:"abb-terra-ac-wallbox-ce-symbiosis"}}, {_id:4292, properties:{technology_type:"", platform_name:"ABB - Terra AC wallbox (JP)", name:"ABB - Terra AC wallbox (JP)", created_at:datetime('2026-05-11T14:45:13.853Z'), id:"abb-terra-ac-wallbox-jp"}}] AS row
